{
  "java": {
    "default": "21",
    "supported": ["17", "21"]
  },
  "gradle": {
    "default": "8.x",
    "supported": ["7.x", "8.x"]
  },
  "springBoot": {
    "default": "3.4.x",
    "supported": ["3.3.x", "3.4.x"]
  },
  "databases": [
    {
      "id": "postgresql",
      "label": "PostgreSQL",
      "gradleDependency": "runtimeOnly 'org.postgresql:postgresql'",
      "driverClass": "org.postgresql.Driver",
      "dialect": "org.hibernate.dialect.PostgreSQLDialect",
      "defaultPort": 5432,
      "jdbcPrefix": "jdbc:postgresql",
      "cliTool": "psql",
      "cliValidateCmd": "psql -h postgres -U {user} -d {db} -c 'SELECT 1' -q -t"
    },
    {
      "id": "mysql",
      "label": "MySQL",
      "gradleDependency": "runtimeOnly 'com.mysql:mysql-connector-j'",
      "driverClass": "com.mysql.cj.jdbc.Driver",
      "dialect": "org.hibernate.dialect.MySQLDialect",
      "defaultPort": 3306,
      "jdbcPrefix": "jdbc:mysql",
      "cliTool": "mysql",
      "cliValidateCmd": "mysql -h mysql -u {user} -p{pass} {db} -e 'SELECT 1'"
    },
    {
      "id": "h2",
      "label": "H2 (in-memory — local/test only)",
      "gradleDependency": "runtimeOnly 'com.h2database:h2'",
      "driverClass": "org.h2.Driver",
      "dialect": "org.hibernate.dialect.H2Dialect",
      "defaultPort": null,
      "jdbcPrefix": "jdbc:h2:mem",
      "cliTool": null,
      "cliValidateCmd": null
    }
  ],
  "messageBrokers": [
    {
      "id": "rabbitmq",
      "label": "RabbitMQ",
      "gradleDependency": "implementation 'org.springframework.boot:spring-boot-starter-amqp'",
      "testDependency": "testImplementation 'org.springframework.amqp:spring-rabbit-test'",
      "cliTool": "curl (management API)",
      "cliValidateCmd": "curl -sf -u guest:guest http://rabbitmq:15672/api/healthchecks/node"
    },
    {
      "id": "kafka",
      "label": "Apache Kafka",
      "gradleDependency": "implementation 'org.springframework.kafka:spring-kafka'",
      "testDependency": "testImplementation 'org.springframework.kafka:spring-kafka-test'",
      "cliTool": "kcat",
      "cliValidateCmd": "kcat -b kafka:29092 -L"
    }
  ],
  "authProviders": [
    {
      "id": "keycloak",
      "label": "Keycloak",
      "rolesClaimType": "nested",
      "rolesClaimParent": "realm_access",
      "rolesClaimField": "roles",
      "principalClaimName": "preferred_username",
      "permissionsClaimName": "permissions"
    },
    {
      "id": "cognito",
      "label": "AWS Cognito",
      "rolesClaimType": "flat",
      "rolesClaimName": "cognito:groups",
      "principalClaimName": "username",
      "permissionsClaimName": "permissions"
    }
  ],
  "dockerImages": {
    "postgres": "postgres:16-alpine",
    "mysql": "mysql:8.0",
    "kafka": "confluentinc/cp-kafka:7.6.0",
    "kafkaZookeeper": "confluentinc/cp-zookeeper:7.6.0",
    "kafkaUi": "provectuslabs/kafka-ui:latest",
    "rabbitmq": "rabbitmq:4-management",
    "keycloak": "quay.io/keycloak/keycloak:26.3.1",
    "redis": "redis:7-alpine",
    "valkey": "valkey/valkey:8-alpine"
  },
  "cacheProviders": [
    {
      "id": "redis",
      "label": "Redis",
      "springDependency": "implementation 'org.springframework.boot:spring-boot-starter-data-redis'",
      "port": 6379,
      "cliTool": "redis-cli",
      "cliValidateCmd": "redis-cli -h cache PING"
    },
    {
      "id": "valkey",
      "label": "Valkey",
      "springDependency": "implementation 'org.springframework.boot:spring-boot-starter-data-redis'",
      "port": 6379,
      "cliTool": "redis-cli",
      "cliValidateCmd": "redis-cli -h cache PING"
    }
  ]
}
