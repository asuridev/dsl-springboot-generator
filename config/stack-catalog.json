{
  "java": {
    "default": "21",
    "supported": ["17", "21"]
  },
  "gradle": {
    "default": "8.x",
    "supported": ["7.x", "8.x"]
  },
  "springBoot": {
    "default": "3.4.x",
    "supported": ["3.3.x", "3.4.x"]
  },
  "databases": [
    {
      "id": "postgresql",
      "label": "PostgreSQL",
      "gradleDependency": "runtimeOnly 'org.postgresql:postgresql'",
      "driverClass": "org.postgresql.Driver",
      "dialect": "org.hibernate.dialect.PostgreSQLDialect",
      "defaultPort": 5432,
      "jdbcPrefix": "jdbc:postgresql",
      "jdbcUrlPattern": "jdbc:postgresql://{host}:{port}/{db}",
      "defaultUser": "postgres",
      "defaultPassword": "postgres",
      "cliTool": "psql",
      "cliVia": "devtools",
      "cliValidateCmd": "psql -h postgres -U {user} -d {db} -c 'SELECT 1' -q -t"
    },
    {
      "id": "mysql",
      "label": "MySQL",
      "gradleDependency": "runtimeOnly 'com.mysql:mysql-connector-j'",
      "driverClass": "com.mysql.cj.jdbc.Driver",
      "dialect": "org.hibernate.dialect.MySQLDialect",
      "defaultPort": 3306,
      "jdbcPrefix": "jdbc:mysql",
      "jdbcUrlPattern": "jdbc:mysql://{host}:{port}/{db}",
      "defaultUser": "postgres",
      "defaultPassword": "postgres",
      "cliTool": "mysql",
      "cliVia": "devtools",
      "cliValidateCmd": "mysql -h mysql -u {user} -p{pass} {db} -e 'SELECT 1'"
    },
    {
      "id": "mariadb",
      "label": "MariaDB",
      "gradleDependency": "runtimeOnly 'org.mariadb.jdbc:mariadb-java-client'",
      "driverClass": "org.mariadb.jdbc.Driver",
      "dialect": "org.hibernate.dialect.MariaDBDialect",
      "defaultPort": 3306,
      "jdbcPrefix": "jdbc:mariadb",
      "jdbcUrlPattern": "jdbc:mariadb://{host}:{port}/{db}",
      "defaultUser": "postgres",
      "defaultPassword": "postgres",
      "cliTool": "mariadb",
      "cliVia": "devtools",
      "cliValidateCmd": "mariadb -h mariadb -u {user} -p{pass} {db} -e 'SELECT 1'"
    },
    {
      "id": "sqlserver",
      "label": "SQL Server",
      "gradleDependency": "runtimeOnly 'com.microsoft.sqlserver:mssql-jdbc'",
      "driverClass": "com.microsoft.sqlserver.jdbc.SQLServerDriver",
      "dialect": "org.hibernate.dialect.SQLServerDialect",
      "defaultPort": 1433,
      "jdbcPrefix": "jdbc:sqlserver",
      "jdbcUrlPattern": "jdbc:sqlserver://{host}:{port};databaseName={db};encrypt=false;trustServerCertificate=true",
      "defaultUser": "sa",
      "defaultPassword": "Str0ng_Passw0rd!",
      "cliTool": "sqlcmd",
      "cliVia": "devtools",
      "cliValidateCmd": "sqlcmd -S sqlserver,1433 -U {user} -P {pass} -d {db} -C -Q 'SELECT 1'"
    },
    {
      "id": "oracle",
      "label": "Oracle Database",
      "gradleDependency": "runtimeOnly 'com.oracle.database.jdbc:ojdbc11'",
      "driverClass": "oracle.jdbc.OracleDriver",
      "dialect": "org.hibernate.dialect.OracleDialect",
      "defaultPort": 1521,
      "serviceName": "FREEPDB1",
      "jdbcPrefix": "jdbc:oracle:thin:@//",
      "jdbcUrlPattern": "jdbc:oracle:thin:@//{host}:{port}/{service}",
      "defaultUser": "appuser",
      "defaultPassword": "Str0ng_Passw0rd1",
      "cliTool": "sqlplus",
      "cliVia": "dbcontainer",
      "cliValidateCmd": "sqlplus -s {user}/{pass}@//localhost:1521/{service}"
    },
    {
      "id": "h2",
      "label": "H2 (in-memory — local/test only)",
      "gradleDependency": "runtimeOnly 'com.h2database:h2'",
      "driverClass": "org.h2.Driver",
      "dialect": "org.hibernate.dialect.H2Dialect",
      "defaultPort": null,
      "jdbcPrefix": "jdbc:h2:mem",
      "jdbcUrlPattern": null,
      "defaultUser": "sa",
      "defaultPassword": "",
      "cliTool": null,
      "cliVia": null,
      "cliValidateCmd": null
    }
  ],
  "messageBrokers": [
    {
      "id": "rabbitmq",
      "label": "RabbitMQ",
      "gradleDependency": "implementation 'org.springframework.boot:spring-boot-starter-amqp'",
      "testDependency": "testImplementation 'org.springframework.amqp:spring-rabbit-test'",
      "cliTool": "curl (management API)",
      "cliValidateCmd": "curl -sf -u guest:guest http://rabbitmq:15672/api/healthchecks/node"
    },
    {
      "id": "kafka",
      "label": "Apache Kafka",
      "gradleDependency": "implementation 'org.springframework.kafka:spring-kafka'",
      "testDependency": "testImplementation 'org.springframework.kafka:spring-kafka-test'",
      "cliTool": "kcat",
      "cliValidateCmd": "kcat -b kafka:29092 -L"
    }
  ],
  "authProviders": [
    {
      "id": "keycloak",
      "label": "Keycloak",
      "rolesClaimType": "nested",
      "rolesClaimParent": "realm_access",
      "rolesClaimField": "roles",
      "principalClaimName": "preferred_username",
      "permissionsClaimName": "permissions"
    },
    {
      "id": "cognito",
      "label": "AWS Cognito",
      "rolesClaimType": "flat",
      "rolesClaimName": "cognito:groups",
      "principalClaimName": "username",
      "permissionsClaimName": "permissions"
    }
  ],
  "dockerImages": {
    "postgres": "postgres:16-alpine",
    "mysql": "mysql:8.0",
    "mariadb": "mariadb:11",
    "sqlserver": "mcr.microsoft.com/mssql/server:2022-latest",
    "oracle": "gvenzl/oracle-free:23-slim",
    "kafka": "confluentinc/cp-kafka:7.6.0",
    "kafkaZookeeper": "confluentinc/cp-zookeeper:7.6.0",
    "kafkaUi": "provectuslabs/kafka-ui:latest",
    "rabbitmq": "rabbitmq:4-management",
    "keycloak": "quay.io/keycloak/keycloak:26.3.1",
    "redis": "redis:7-alpine",
    "valkey": "valkey/valkey:8-alpine",
    "minio": "minio/minio:latest",
    "minioClient": "minio/mc:latest"
  },
  "storageProviders": [
    {
      "id": "minio",
      "label": "MinIO (S3-compatible)",
      "gradleDependency": [
        "implementation 'software.amazon.awssdk:s3:2.31.6'"
      ],
      "defaultPort": 9000,
      "consolePort": 9001,
      "region": "us-east-1",
      "cliTool": "mc",
      "cliValidateCmd": "mc alias set local http://minio:9000 $MINIO_ROOT_USER $MINIO_ROOT_PASSWORD && mc ls local"
    }
  ],
  "cacheProviders": [
    {
      "id": "redis",
      "label": "Redis",
      "springDependency": "implementation 'org.springframework.boot:spring-boot-starter-data-redis'",
      "port": 6379,
      "cliTool": "redis-cli",
      "cliValidateCmd": "redis-cli -h cache PING"
    },
    {
      "id": "valkey",
      "label": "Valkey",
      "springDependency": "implementation 'org.springframework.boot:spring-boot-starter-data-redis'",
      "port": 6379,
      "cliTool": "redis-cli",
      "cliValidateCmd": "redis-cli -h cache PING"
    }
  ]
}
