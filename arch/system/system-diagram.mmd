C4Container
    title Canasta Shop — C4 Contenedores (L2)

    Person(customer, "Cliente", "Consumidor final que compra productos de canasta familiar")
    Person(operator, "Operador Interno", "Administrador que gestiona catálogo, stock y repartidores")

    System_Ext(paymentGateway, "Payment Gateway", "Procesador externo de pagos con tarjeta (ej: Stripe, Mercado Pago)")

    Boundary(b0, "Canasta Shop") {
        Container(catalog, "catalog", "Core Domain", "Gestión de productos, categorías y precios. Fuente autoritativa del catálogo.")
        Container(orders, "orders", "Core Domain", "Ciclo de vida del pedido: carrito, checkout, tracking. Orquesta el CheckoutSaga.")
        Container(customers, "customers", "Core Domain", "Perfiles de clientes, autenticación y direcciones de entrega.")
        Container(inventory, "inventory", "Supporting Domain", "Control de stock en tiempo real. Reserva y libera unidades por pedido.")
        Container(payments, "payments", "Supporting Domain", "Procesamiento de cobros con tarjeta y registro de pagos en efectivo.")
        Container(delivery, "delivery", "Supporting Domain", "Gestión de entregas a domicilio con flota propia.")
        Container(notifications, "notifications", "Supporting Domain", "Despacho de notificaciones transaccionales por email, SMS y push.")
    }

    Rel(customer, orders, "Navega catálogo, gestiona carrito y hace checkout")
    Rel(customer, customers, "Se registra e inicia sesión")
    Rel(operator, catalog, "Gestiona productos, categorías y precios")
    Rel(operator, inventory, "Ajusta niveles de stock manualmente")
    Rel(operator, delivery, "Gestiona repartidores y monitorea entregas")

    Rel(catalog, inventory, "ProductActivated / ProductDiscontinued", "Event / Message Broker")
    Rel(catalog, orders, "ProductPriceChanged / ProductActivated / ProductDiscontinued", "Event / Message Broker")
    Rel(orders, inventory, "OrderPlaced / OrderCancelled", "Event / Message Broker")
    Rel(inventory, orders, "StockReserved / StockReservationFailed / StockReleased", "Event / Message Broker")
    Rel(orders, payments, "OrderPaymentRequired / OrderCancelled", "Event / Message Broker")
    Rel(payments, orders, "PaymentApproved / PaymentFailed", "Event / Message Broker")
    Rel(orders, delivery, "OrderConfirmed / OrderCancelled", "Event / Message Broker")
    Rel(delivery, orders, "OrderDelivered", "Event / Message Broker")
    Rel(orders, notifications, "OrderConfirmed / OrderCancelled", "Event / Message Broker")
    Rel(delivery, notifications, "DeliveryAssigned / OrderDelivered", "Event / Message Broker")
    Rel(payments, paymentGateway, "processCardPayment / refundPayment", "ACL / HTTPS")

    %% ── Conexiones por evento → naranja ─────────────────────────
    UpdateRelStyle(catalog, inventory, $lineColor="orange", $textColor="darkorange")
    UpdateRelStyle(catalog, orders, $lineColor="orange", $textColor="darkorange")
    UpdateRelStyle(orders, inventory, $lineColor="orange", $textColor="darkorange")
    UpdateRelStyle(inventory, orders, $lineColor="orange", $textColor="darkorange")
    UpdateRelStyle(orders, payments, $lineColor="orange", $textColor="darkorange")
    UpdateRelStyle(payments, orders, $lineColor="orange", $textColor="darkorange")
    UpdateRelStyle(orders, delivery, $lineColor="orange", $textColor="darkorange")
    UpdateRelStyle(delivery, orders, $lineColor="orange", $textColor="darkorange")
    UpdateRelStyle(orders, notifications, $lineColor="orange", $textColor="darkorange")
    UpdateRelStyle(delivery, notifications, $lineColor="orange", $textColor="darkorange")
