classDiagram
    class Category {
        +Uuid id
        +String name
        +String slug
        +Text description
        +Integer displayOrder
        +CategoryStatus status
        +DateTime createdAt
        +DateTime updatedAt
    }

    class Product {
        +Uuid id
        +String name
        +String slug
        +Text description
        +String sku
        +Money price
        +Uuid categoryId
        +ProductStatus status
        +DateTime createdAt
        +DateTime updatedAt
    }

    class ProductImage {
        +Uuid id
        +Url url
        +String altText
        +Integer displayOrder
    }

    class PriceHistory {
        +Uuid id
        +Money previousPrice
        +Money newPrice
        +DateTime changedAt
    }

    class Money {
        +Decimal amount
        +String currency
    }

    class CategoryStatus {
        <<enumeration>>
        ACTIVE
        INACTIVE
    }

    class ProductStatus {
        <<enumeration>>
        DRAFT
        ACTIVE
        DISCONTINUED
    }

    Product "1" *-- "0..*" ProductImage : composition
    Product "1" *-- "0..*" PriceHistory : composition
    Product "0..*" --> "1" Category : association
    Product ..> Money : uses
    Category ..> CategoryStatus : uses
    Product ..> ProductStatus : uses
