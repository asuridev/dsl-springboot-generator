sequenceDiagram
    participant Op as Operator
    participant CatalogAPI as Catalog API
    participant ProductDomain as Product Domain
    participant MQ as RabbitMQ
    participant Inventory as inventory BC
    participant Orders as orders BC

    Op ->> CatalogAPI: PATCH /products/{id}/discontinue
    CatalogAPI ->> ProductDomain: discontinue()
    ProductDomain ->> ProductDomain: verify CAT-RULE-002 (not already DISCONTINUED)
    ProductDomain ->> ProductDomain: transition status -> DISCONTINUED (terminal)
    ProductDomain -->> CatalogAPI: OK
    CatalogAPI ->> MQ: publish ProductDiscontinued (catalog.product.discontinued)
    MQ ->> Inventory: ProductDiscontinued consumed - closes StockItem
    MQ ->> Orders: ProductDiscontinued consumed - marks product unavailable in CatalogSnapshot
    CatalogAPI -->> Op: 204 No Content
