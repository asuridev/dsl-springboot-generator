package <%- packageName %>.<%- bc %>.infrastructure.persistence.entities;

import jakarta.persistence.*;
import lombok.*;
<% imports.forEach(imp => { %>import <%- imp %>;
<% }); %>

/**
 * <%- name %>Jpa — JPA Entity for <%- name %> aggregate.
<% if (description) { %> * <%- description.trim().replace(/\n\s*/g, '\n * ') %>
<% } %> */
@Getter
@Setter
@NoArgsConstructor
@AllArgsConstructor
@Builder
@Entity
@Table(
    name = "<%- tableName %>"<%
if (indexes.length > 0) { %>,
    indexes = {<%
  indexes.forEach((idx, i) => { %>
        @Index(name = "<%- idx.name %>", columnList = "<%- idx.columnList %>")<%- i < indexes.length - 1 ? ',' : '' %><%
  }); %>
    }<%
} %><%
if (typeof uniqueConstraints !== 'undefined' && uniqueConstraints.length > 0) { %>,
    uniqueConstraints = {<%
  uniqueConstraints.forEach((uc, i) => { %>
        @UniqueConstraint(name = "<%- uc.name %>", columnNames = "<%- uc.columnNames %>")<%- i < uniqueConstraints.length - 1 ? ',' : '' %><%
  }); %>
    }<%
} %>
)
<% if (hasSoftDelete) { %>@org.hibernate.annotations.SQLRestriction("deleted_at IS NULL")
<% } %>public class <%- name %>Jpa<% if (baseClass) { %> extends <%- baseClass %><% } %> {

    @Id
    @Column(name = "id", nullable = false, updatable = false)
    private UUID id;

<% if (hasVersion) { %>    @Version
    @Column(name = "version", nullable = false)
    private Long version;

<% } %><% fields.forEach(field => { %>    <%- field.columnAnnotation %>
    private <%- field.javaType %> <%- field.name %><% if (field.isCollection) { %> = new ArrayList<>()<% } %>;

<% }); %>
<% childEntities.forEach(entity => {
  let cascadeSpec;
  if (entity.immutable) {
    cascadeSpec = 'cascade = { CascadeType.PERSIST }, orphanRemoval = false';
  } else if (entity.relationship === 'aggregation') {
    cascadeSpec = 'cascade = { CascadeType.PERSIST, CascadeType.MERGE }, orphanRemoval = false';
  } else {
    cascadeSpec = 'cascade = CascadeType.ALL, orphanRemoval = true';
  }
  const relAnnotation = entity.isOneToOne ? 'OneToOne' : 'OneToMany';
%>    @<%- relAnnotation %>(<%- cascadeSpec %>, fetch = FetchType.LAZY)
    @JoinColumn(name = "<%- entity.joinColumn %>", nullable = <%- entity.isOneToOne ? 'true' : 'false' %>)
<% if (!entity.isOneToOne) { %>    @Builder.Default
    private List<<%- entity.jpaName %>> <%- entity.fieldName %> = new ArrayList<>();
<% } else { %>    private <%- entity.jpaName %> <%- entity.fieldName %>;
<% } %>
<% }); %>}
