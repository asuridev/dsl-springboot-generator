package <%- packageName %>.<%- bc %>.infrastructure.persistence.repositories;

import org.springframework.data.jpa.repository.JpaRepository;
import org.springframework.data.jpa.repository.Query;
import org.springframework.data.repository.query.Param;
import org.springframework.stereotype.Repository;
import java.util.Optional;
import java.util.UUID;
<% imports.forEach(imp => { %>import <%- imp %>;
<% }); %>

/**
 * <%- aggregateName %>JpaRepository — Spring Data JPA repository for <%- jpaEntityName %>.
 * Inherited from JpaRepository: findById, findAll, save, delete, count, etc.
 */
@Repository
public interface <%- aggregateName %>JpaRepository extends JpaRepository<<%- jpaEntityName %>, UUID> {
<% customMethods.forEach(method => { %>
<% if (method.modifying) { %>    @Modifying
    @Transactional
<% } %><% if (method.query) { %>    @Query("<%- method.query %>")
<% } %>    <%- method.returnType %> <%- method.name %>(<%- method.paramsStr %>);
<% }); %>}
