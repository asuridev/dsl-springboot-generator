package <%- packageName %>.<%- bc %>.infrastructure.persistence.mappers;

import org.springframework.stereotype.Component;
<% imports.forEach(imp => { %>import <%- imp %>;
<% }); %>

/**
 * <%- aggregateName %>JpaMapper — stateless converter between the domain model
 * and its JPA representation.
 *
 * Extracted from <%- aggregateName %>RepositoryImpl to keep the adapter focused
 * on persistence orchestration. All conversions are pure functions; introduce
 * dependencies (e.g. value-object factories) only if a domain rule explicitly
 * requires them.
 */
@Component
public class <%- aggregateName %>JpaMapper {

    // ─── JPA → Domain ────────────────────────────────────────────────────────

    public <%- aggregateName %> toDomain(<%- jpaEntityName %> jpa) {
        <%- toDomainBody %>
    }
<% childEntityMappers.forEach(cem => { %>
    public <%- cem.entityName %> to<%- cem.entityName %>Domain(<%- cem.entityName %>Jpa jpa) {
        <%- cem.toDomainBody %>
    }
<% }); %>

    // ─── Domain → JPA ────────────────────────────────────────────────────────

    public <%- jpaEntityName %> toJpa(<%- aggregateName %> domain) {
        <%- toJpaBody %>
    }
<% childEntityMappers.forEach(cem => { %>
    public <%- cem.entityName %>Jpa to<%- cem.entityName %>Jpa(<%- cem.entityName %> domain) {
        <%- cem.toJpaBody %>
    }
<% }); %>}
