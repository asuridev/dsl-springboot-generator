package <%- packageName %>.<%- moduleName %>.infrastructure.adapters.<%- targetBcPackage %>;

import feign.Logger;
import feign.Request;
<%_ if (auth) { _%>
import feign.RequestInterceptor;
<%_ } _%>
<%_ if (auth && (auth.type === 'api-key' || auth.type === 'bearer')) { _%>
import org.springframework.beans.factory.annotation.Value;
<%_ } _%>
<%_ if (auth && auth.type === 'oauth2-cc') { _%>
import <%- packageName %>.shared.infrastructure.auth.OAuth2ClientCredentialsSupport;
<%_ } _%>
import org.springframework.context.annotation.Bean;

import java.util.concurrent.TimeUnit;

<%
const _connectMs = (resilience && resilience.connectTimeoutMs) || 5000;
const _readMs    = (resilience && resilience.timeoutMs)        || 30000;
%>
<%- derivedFromComment %>
/**
 * Feign configuration for the <%- targetBc %> external system.
 * Not annotated with @Configuration — registered via @FeignClient(configuration=...).
<%_ if (resilience) { _%>
 *
 * derived_from: system.yaml#/externalSystems[<%- targetBc %>]/resilience
<%_ } _%>
<%_ if (auth) { _%>
 *
 * derived_from: system.yaml#/externalSystems[<%- targetBc %>]/auth (type: <%- auth.type %>)
<%_ } _%>
 */
public class <%- feignConfigClassName %> {
<%_ if (auth && auth.type === 'api-key') { _%>

    @Value("${<%- auth.valueProperty || ('integration.' + targetBc + '.api-key') %>:}")
    private String apiKey;

    @Bean
    public RequestInterceptor <%- targetBcPackage %>AuthInterceptor() {
        return template -> {
            if (apiKey != null && !apiKey.isBlank()) {
                template.header("<%- auth.header || 'X-Api-Key' %>", apiKey);
            }
        };
    }
<%_ } else if (auth && auth.type === 'bearer') { _%>

    @Value("${<%- auth.valueProperty || ('integration.' + targetBc + '.bearer-token') %>:}")
    private String bearerToken;

    @Bean
    public RequestInterceptor <%- targetBcPackage %>AuthInterceptor() {
        return template -> {
            if (bearerToken != null && !bearerToken.isBlank()) {
                template.header("Authorization", "Bearer " + bearerToken);
            }
        };
    }
<%_ } else if (auth && auth.type === 'oauth2-cc') { _%>

    private final OAuth2ClientCredentialsSupport oauth2Support;

    public <%- feignConfigClassName %>(OAuth2ClientCredentialsSupport oauth2Support) {
        this.oauth2Support = oauth2Support;
    }

    @Bean
    public RequestInterceptor <%- targetBcPackage %>AuthInterceptor() {
        return oauth2Support.buildInterceptor("<%- auth.credentialKey %>");
    }
<%_ } _%>

    @Bean
    public Logger.Level feignLoggerLevel() {
        return Logger.Level.BASIC;
    }

    @Bean
    public Request.Options feignOptions() {
        return new Request.Options(
            <%- _connectMs %>L, TimeUnit.MILLISECONDS,   // connect timeout
            <%- _readMs %>L, TimeUnit.MILLISECONDS,   // read timeout
            true
        );
    }
}
