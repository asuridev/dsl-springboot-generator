package <%- packageName %>.<%- moduleName %>.domain.models.<%- targetBcPackage %>;
<%
const needsBigDecimal = fields && fields.some(f => f.javaType === 'BigDecimal');
const needsInstant    = fields && fields.some(f => f.javaType === 'Instant');
const needsUUID       = fields && fields.some(f => f.javaType && f.javaType.includes('java.util.UUID'));
const needsList       = fields && fields.some(f => f.javaType && f.javaType.startsWith('List'));
%>
<%_ if (needsBigDecimal) { _%>
import java.math.BigDecimal;
<%_ } _%>
<%_ if (needsInstant) { _%>
import java.time.Instant;
<%_ } _%>
<%_ if (needsUUID) { _%>
import java.util.UUID;
<%_ } _%>
<%_ if (needsList) { _%>
import java.util.List;
<%_ } _%>

<%- derivedFromComment %>
/**
 * Domain model for {@code <%- name %>} returned from {@link <%- aclMapperClassName %>}.
 *
 * <p>This is the domain-side view of the external <%- targetBc %> response.
 * The corresponding wire-format DTO lives under
 * {@code infrastructure.adapters.<%- targetBcPackage %>.dtos}.
 * If the external API changes, only the ACL mapper needs updating.
 */
public record <%- name %>(
<%_ fields.forEach((f, i) => { _%>
    <%_ if (f.derivedFromComment) { _%><%- f.derivedFromComment %>
    <%_ } _%><%- f.javaType.replace('java.util.UUID', 'UUID') %> <%- f.name %><%- i < fields.length - 1 ? ',' : '' %>
<%_ }); _%>
) {}
