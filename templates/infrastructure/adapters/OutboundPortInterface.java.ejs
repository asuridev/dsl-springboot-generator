package <%- packageName %>.<%- moduleName %>.application.ports;

<%
const _allQueryParams = operations.flatMap(op => op.queryParams || []);
const needsBigDecimal = domainModels.some(dm => dm.fields.some(f => f.javaType === 'BigDecimal'))
  || _allQueryParams.some(qp => qp.javaType === 'BigDecimal');
const needsInstant    = domainModels.some(dm => dm.fields.some(f => f.javaType === 'Instant'))
  || _allQueryParams.some(qp => qp.javaType === 'Instant');
const needsList       = operations.some(op => op.returnList);
const uniqueDomainTypes = [...new Set(operations.filter(op => op.hasDomainReturn).map(op => op.domainType))];
const uniqueReqDtos   = [...new Set(operations.filter(op => op.hasBody && op.requestDtoName).map(op => op.requestDtoName))];
%>
<%_ if (needsBigDecimal) { _%>
import java.math.BigDecimal;
<%_ } _%>
<%_ if (needsInstant) { _%>
import java.time.Instant;
<%_ } _%>
<%_ if (needsList) { _%>
import java.util.List;
<%_ } _%>
<%_ if (fkMethods && fkMethods.length > 0) { _%>
import java.util.UUID;
<%_ } _%>
<%_ uniqueDomainTypes.forEach(dt => { _%>
import <%- packageName %>.<%- moduleName %>.domain.models.<%- targetBcPackage %>.<%- dt %>;
<%_ }); _%>
<%_ uniqueReqDtos.forEach(dto => { _%>
import <%- packageName %>.<%- moduleName %>.infrastructure.adapters.<%- targetBcPackage %>.dtos.<%- dto %>;
<%_ }); _%>

/**
 * Output port — anti-corruption boundary to the <%- targetBc %> bounded context.
 * Implementations live in infrastructure/adapters/<%- targetBcPackage %>/.
 *
 * <p>This interface is the single dependency point for all <%- targetBc %> interactions:
 * business operations (from <%- targetBc %>-internal-api.yaml) and FK validations.
 */
public interface <%- portInterfaceName %> {

<%_ operations.forEach(op => { _%>
    /**
     * <%- op.description %>
     */
<%_   const returnType = !op.hasDomainReturn ? 'void'
        : op.returnList ? `List<${op.domainType}>`
        : op.domainType; _%>
<%_   const params = [];
      op.pathVariables.forEach(pv => params.push(`String ${pv}`));
      if (op.hasBody) params.push(`${op.requestDtoName} body`);
      (op.queryParams || []).forEach(qp => params.push(`${qp.javaType} ${qp.name}`)); _%>
    <%- returnType %> <%- op.methodName %>(<%- params.join(', ') %>);

<%_ }); _%>
<%_ fkMethods.forEach(fk => { _%>
    /**
     * Returns true if a <%- fk.aggregate %> with the given id exists and is active in <%- targetBc %>.
     * Used for FK validation before persisting aggregates that reference cross-BC entities.
     */
    boolean <%- fk.methodName %>(UUID id);

<%_ }); _%>
}
