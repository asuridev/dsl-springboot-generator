package <%- packageName %>.<%- bc %>.infrastructure.persistence.entities;

import jakarta.persistence.*;
import lombok.*;
<% imports.forEach(imp => { %>import <%- imp %>;
<% }); %>
<% if (immutable) { %>import org.hibernate.annotations.Immutable;
<% } %>

/**
 * <%- name %>Jpa — JPA Entity for <%- name %> child entity.
<% if (description) { %> * <%- description.trim().replace(/\n\s*/g, '\n * ') %>
<% } %><% if (immutable) { %> * Immutable: insert-only record. No updates or deletes on individual rows.
<% } %> */
@Getter
@Setter
@NoArgsConstructor
@AllArgsConstructor
@Builder
@Entity
@Table(name = "<%- tableName %>")
<% if (immutable) { %>@Immutable
<% } %>public class <%- name %>Jpa {

    @Id
    @Column(name = "id", nullable = false, updatable = false)
    private UUID id;

<% fields.forEach(field => { %>    <%- field.columnAnnotation %>
    private <%- field.javaType %> <%- field.name %>;

<% }); %>}
