package <%- packageName %>.<%- moduleName %>.infrastructure.projectionUpdaters;

import <%- packageName %>.<%- moduleName %>.infrastructure.persistence.projections.<%- projectionName %>Jpa;
import <%- packageName %>.<%- moduleName %>.infrastructure.persistence.projections.<%- projectionName %>JpaRepository;
import <%- packageName %>.shared.infrastructure.eventEnvelope.EventEnvelope;

import com.fasterxml.jackson.core.JsonProcessingException;
import com.fasterxml.jackson.core.type.TypeReference;
import com.fasterxml.jackson.databind.ObjectMapper;
import com.rabbitmq.client.Channel;
import org.slf4j.Logger;
import org.slf4j.LoggerFactory;
import org.springframework.amqp.core.Message;
import org.springframework.amqp.rabbit.annotation.RabbitListener;
import org.springframework.stereotype.Component;
import org.springframework.transaction.annotation.Transactional;

import java.io.IOException;
import java.time.Instant;
import java.util.Map;
import java.util.Optional;
<% if (needsBigDecimal) { %>import java.math.BigDecimal;
<% } %><% if (needsLocalDate) { %>import java.time.LocalDate;
<% } %><% if (needsUUID) { %>import java.util.UUID;
<% } %><% if (needsDuration) { %>import java.time.Duration;
<% } %><% if (needsURI) { %>import java.net.URI;
<% } %>
/**
 * Partial projection updater for <%- projectionName %> — handles <%- sourceEvent %>.
 * Only updates fields: <%- updatesFields.join(', ') %>.
 * Never inserts new rows — if the key does not exist, the event is discarded.
 * derived_from: bc.<%- moduleName %>.projections[<%- projectionName %>].additionalSources[event=<%- sourceEvent %>]
 * upsertStrategy: <%- upsertStrategy %> (inherited from projection)
 */
@Component("<%- moduleName %>.<%- projectionName %>On<%- sourceEventPascal %>ProjectionUpdater")
public class <%- projectionName %>On<%- sourceEventPascal %>ProjectionUpdater {

    private static final Logger log = LoggerFactory.getLogger(<%- projectionName %>On<%- sourceEventPascal %>ProjectionUpdater.class);

    private final <%- projectionName %>JpaRepository repository;
    private final ObjectMapper objectMapper;

    public <%- projectionName %>On<%- sourceEventPascal %>ProjectionUpdater(<%- projectionName %>JpaRepository repository, ObjectMapper objectMapper) {
        this.repository = repository;
        this.objectMapper = objectMapper;
    }

    @RabbitListener(queues = "${queues.<%- queueKey %>}")
    @Transactional
    public void handle(Message message, Channel channel) throws IOException {
        long deliveryTag = message.getMessageProperties().getDeliveryTag();

        EventEnvelope<Map<String, Object>> event;
        try {
            event = objectMapper.readValue(
                    message.getBody(),
                    new TypeReference<EventEnvelope<Map<String, Object>>>() {});
        } catch (JsonProcessingException e) {
            log.error("Fatal deserialization error in partial projection updater — sending to DLQ: {}", e.getMessage());
            channel.basicNack(deliveryTag, false, false);
            return;
        }

        try {
            Map<String, Object> data = event.data();
            <%- keyJavaType %> key = objectMapper.convertValue(data.get("<%- keyByField %>"), <%- keyJavaType %>.class);
            if (key == null) {
                log.warn("Partial projection event for <%- projectionName %> (<%- sourceEvent %>) missing keyBy field <%- keyByField %> — discarding");
                channel.basicAck(deliveryTag, false);
                return;
            }

            Optional<<%- projectionName %>Jpa> existing = repository.findById(key);
            if (existing.isEmpty()) {
                log.debug("Partial projection updater: key={} not found in <%- projectionName %> — discarding <%- sourceEvent %> (row not yet created by primary source)", key);
                channel.basicAck(deliveryTag, false);
                return;
            }
<% if (upsertStrategy === 'versionGuarded' && versionField) { %>
            // Version guard: skip stale updates
            <%- versionJavaType %> incomingVersion = objectMapper.convertValue(data.get("<%- versionField %>"), <%- versionJavaType %>.class);
            if (incomingVersion != null && existing.get().get<%- versionFieldCap %>() != null
                    && incomingVersion.compareTo(existing.get().get<%- versionFieldCap %>()) <= 0) {
                log.debug("Skipping stale partial projection update for <%- projectionName %> (<%- sourceEvent %>) key={} (incoming v{} <= stored v{})",
                        key, incomingVersion, existing.get().get<%- versionFieldCap %>());
                channel.basicAck(deliveryTag, false);
                return;
            }
<% } %>
            <%- projectionName %>Jpa row = existing.get();
<% updatesFieldsData.forEach(f => { %>            row.set<%- f.cap %>(objectMapper.convertValue(data.get("<%- f.name %>"), <%- f.javaType %>.class));
<% }); %>            row.setLastUpdatedAt(Instant.now());
            repository.save(row);

            channel.basicAck(deliveryTag, false);
        } catch (RuntimeException e) {
            log.warn("Partial projection updater error — will retry. queue={}, error={}",
                    message.getMessageProperties().getConsumerQueue(), e.getMessage(), e);
            throw e;
        }
    }
}
