spring:
  config:
    import:
      - "classpath:parameters/develop/db.yaml"
      - "classpath:parameters/develop/cors.yaml"
<%- hasMessaging ? '      - "classpath:parameters/develop/' + broker + '.yaml"' : '' %>
<%- hasHttpIntegrations ? '      - "classpath:parameters/develop/urls.yaml"' : '' %>
<%- resilienceEnabled ? '      - "classpath:parameters/develop/resilience.yaml"' : '' %>
<%- oauth2ClientEnabled ? '      - "classpath:parameters/develop/oauth2.yaml"' : '' %>
<%- mtlsEnabled ? '      - "classpath:parameters/develop/mtls.yaml"' : '' %>
