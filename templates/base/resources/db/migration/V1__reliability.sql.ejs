-- derived_from: system.yaml#/infrastructure/reliability
-- Tables backing the transactional outbox and consumer idempotency log.
-- Generated only when system.infrastructure.reliability.{outbox|consumerIdempotency} is true.

<% if (outboxEnabled) { %>
<%- sql.createTable('outbox_event') %> (
    id           <%- sql.uuid %>         NOT NULL,
    destination  <%- sql.varchar(255) %> NOT NULL,
    routing_key  <%- sql.varchar(255) %>,
    event_type   <%- sql.varchar(512) %> NOT NULL,
    payload      <%- sql.text %>         NOT NULL,
    created_at   <%- sql.timestamp %>    NOT NULL,
    published_at <%- sql.timestamp %>,
    attempts     <%- sql.integer %>      NOT NULL DEFAULT 0,
    last_error   <%- sql.varchar(1024) %>,
    CONSTRAINT pk_outbox_event PRIMARY KEY (id)
);

<%- sql.createIndex('idx_outbox_pending', 'outbox_event', 'published_at, created_at') %>;
<% } %>
<% if (consumerIdempotencyEnabled) { %>
<%- sql.createTable('processed_event') %> (
    handler_id   <%- sql.varchar(512) %> NOT NULL,
    event_id     <%- sql.varchar(64) %>  NOT NULL,
    processed_at <%- sql.timestamp %>    NOT NULL,
    CONSTRAINT pk_processed_event PRIMARY KEY (handler_id, event_id)
);
<% } %>
