-- ─── Request idempotency ───────────────────────────────────────────────────
-- derived_from: useCases[*].idempotency.storage = database
--
-- Stores responses returned for an Idempotency-Key (or other configured
-- header) so retries within the TTL window replay the original outcome.

<%- sql.createTable('idempotency_request') %> (
    idempotency_key       <%- sql.varchar(255) %> NOT NULL PRIMARY KEY,
    request_hash          <%- sql.varchar(128) %> NOT NULL,
    response_status       <%- sql.integer %>      NOT NULL,
    response_body         <%- sql.bytea %>,
    response_content_type <%- sql.varchar(128) %>,
    expires_at            <%- sql.timestamp %>    NOT NULL
);

<%- sql.createIndex('idx_idempotency_request_expires_at', 'idempotency_request', 'expires_at') %>;
