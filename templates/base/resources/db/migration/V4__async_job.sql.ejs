-- ─── Async job tracking ───────────────────────────────────────────────────
-- derived_from: useCases[*].async.mode = jobTracking
--
-- Persists job rows for command use cases that declare `async: { mode:
-- jobTracking }`. The handler inserts a PENDING row and returns its id;
-- a worker (out of scope for the generator — see the // TODO emitted by
-- the handler) transitions the status and writes the result.

<%- sql.createTable('async_job') %> (
    id          <%- sql.uuid %>         NOT NULL PRIMARY KEY,
    type        <%- sql.varchar(128) %> NOT NULL,
    status      <%- sql.varchar(16) %>  NOT NULL,
    payload     <%- sql.bytea %>,
    result      <%- sql.bytea %>,
    created_at  <%- sql.timestamp %>    NOT NULL,
    updated_at  <%- sql.timestamp %>    NOT NULL
);

<%- sql.createIndex('idx_async_job_status', 'async_job', 'status') %>;

<%- sql.createIndex('idx_async_job_type', 'async_job', 'type') %>;
