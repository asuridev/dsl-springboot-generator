spring:
  config:
    import:
      - "classpath:parameters/production/db.yaml"
      - "classpath:parameters/production/cors.yaml"
<%- hasMessaging ? '      - "classpath:parameters/production/' + broker + '.yaml"' : '' %>
<%- hasHttpIntegrations ? '      - "classpath:parameters/production/urls.yaml"' : '' %>
<%- resilienceEnabled ? '      - "classpath:parameters/production/resilience.yaml"' : '' %>
<%- oauth2ClientEnabled ? '      - "classpath:parameters/production/oauth2.yaml"' : '' %>
<%- mtlsEnabled ? '      - "classpath:parameters/production/mtls.yaml"' : '' %>
<% if (authServerEnabled) { -%>
      - "classpath:parameters/production/auth-server.yaml"
<% } -%>

springdoc:
  swagger-ui:
    enabled: false
