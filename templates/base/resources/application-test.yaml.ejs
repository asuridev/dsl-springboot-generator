spring:
  config:
    import:
      - "classpath:parameters/test/db.yaml"
      - "classpath:parameters/test/cors.yaml"
<%- hasMessaging ? '      - "classpath:parameters/test/' + broker + '.yaml"' : '' %>
<%- hasHttpIntegrations ? '      - "classpath:parameters/test/urls.yaml"' : '' %>
<%- resilienceEnabled ? '      - "classpath:parameters/test/resilience.yaml"' : '' %>
<%- oauth2ClientEnabled ? '      - "classpath:parameters/test/oauth2.yaml"' : '' %>
<%- mtlsEnabled ? '      - "classpath:parameters/test/mtls.yaml"' : '' %>
<% if (objectStoragePresent) { -%>
      - "classpath:parameters/test/storage.yaml"
<% } -%>
<% if (authServerEnabled) { -%>
      - "classpath:parameters/test/auth-server.yaml"
<% } -%>
