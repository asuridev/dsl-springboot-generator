spring:
  config:
    import:
      - "classpath:parameters/local/db.yaml"
      - "classpath:parameters/local/cors.yaml"
<%- hasMessaging ? '      - "classpath:parameters/local/' + broker + '.yaml"' : '' %>
<%- hasHttpIntegrations ? '      - "classpath:parameters/local/urls.yaml"' : '' %>
<%- resilienceEnabled ? '      - "classpath:parameters/local/resilience.yaml"' : '' %>
<%- oauth2ClientEnabled ? '      - "classpath:parameters/local/oauth2.yaml"' : '' %>
<%- mtlsEnabled ? '      - "classpath:parameters/local/mtls.yaml"' : '' %>
<% if (objectStoragePresent) { -%>
      - "classpath:parameters/local/storage.yaml"
<% } -%>
<% if (authServerEnabled) { -%>
      - "classpath:parameters/local/auth-server.yaml"
<% } -%>
