spring:
  datasource:
    url: <%= jdbcUrl %>
    username: ${DB_USERNAME}
    password: ${DB_PASSWORD}
    driver-class-name: <%= driverClass %>
  jpa:
    hibernate:
      ddl-auto: validate
    show-sql: false
    properties:
      hibernate:
        format_sql: false
        dialect: <%= dialect %>

logging:
  level:
    root: WARN
    <%= packageName %>: INFO
