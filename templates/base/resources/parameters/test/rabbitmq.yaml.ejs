spring:
  rabbitmq:
    host: localhost
    port: 5672
    username: guest
    password: guest
    virtual-host: /
    publisher-confirm-type: correlated
    publisher-returns: true
    listener:
      simple:
        acknowledge-mode: manual
        concurrency: 1
        prefetch: 1
        retry:
          enabled: true
          max-attempts: 2
          initial-interval: 500
          multiplier: 1.0
          max-interval: 1000
          stateless: true
<% if (topology && topology.exchanges.length > 0) { %>
exchanges:
<% topology.exchanges.forEach(e => { %>  <%- e.key %>: <%- e.value %>
<% }); %>
<% } %>
<% if (topology && topology.queues.length > 0) { %>
queues:
<% topology.queues.forEach(q => { %>  <%- q.key %>: <%- q.value %>
<% }); %>
<% } %>
<% if (topology && topology.routingKeys.length > 0) { %>
routing-keys:
<% topology.routingKeys.forEach(rk => { %>  <%- rk.key %>: <%- rk.value %>
<% }); %>
<% } %>
