spring:
  datasource:
    url: <%= jdbcUrl %>
    username: <%= databaseUsername %>
    password: <%= databasePassword %>
    driver-class-name: <%= driverClass %>
  jpa:
    hibernate:
      ddl-auto: update
    show-sql: true
    properties:
      hibernate:
        format_sql: true
        dialect: <%= dialect %>

logging:
  level:
    root: INFO
    <%= packageName %>: DEBUG
