# derived_from: system.yaml#/integrations[*]/resilience
#
# Resilience4j defaults for outbound HTTP integrations.
# Each integration's @CircuitBreaker(name = "<targetBc>") and
# @Retry(name = "<targetBc>") resolves to the "default" config below unless
# there is a specific override under instances.<targetBc>.
<%
const _instances = Array.isArray(resilienceInstances) ? resilienceInstances : [];
const _cbInstances  = _instances.filter(i => i.circuitBreaker && Object.keys(i.circuitBreaker).length > 0);
const _retInstances = _instances.filter(i => i.retries      && Object.keys(i.retries).length      > 0);
%>
resilience4j:
  circuitbreaker:
    configs:
      default:
        registerHealthIndicator: true
        slidingWindowType: COUNT_BASED
        slidingWindowSize: 20
        minimumNumberOfCalls: 10
        failureRateThreshold: 50
        waitDurationInOpenState: 30s
        permittedNumberOfCallsInHalfOpenState: 3
        automaticTransitionFromOpenToHalfOpenEnabled: true
<%_ if (_cbInstances.length > 0) { _%>
    instances:
<%_   _cbInstances.forEach(inst => { _%>
      <%- inst.name %>:
        baseConfig: default
<%_     if (inst.circuitBreaker.failureRateThreshold != null) { _%>
        failureRateThreshold: <%- inst.circuitBreaker.failureRateThreshold %>
<%_     } _%>
<%_     if (inst.circuitBreaker.waitDurationInOpenState != null) { _%>
        waitDurationInOpenState: <%- inst.circuitBreaker.waitDurationInOpenState %>
<%_     } _%>
<%_     if (inst.circuitBreaker.slidingWindowSize != null) { _%>
        slidingWindowSize: <%- inst.circuitBreaker.slidingWindowSize %>
<%_     } _%>
<%_     if (inst.circuitBreaker.minimumNumberOfCalls != null) { _%>
        minimumNumberOfCalls: <%- inst.circuitBreaker.minimumNumberOfCalls %>
<%_     } _%>
<%_     if (inst.circuitBreaker.permittedNumberOfCallsInHalfOpenState != null) { _%>
        permittedNumberOfCallsInHalfOpenState: <%- inst.circuitBreaker.permittedNumberOfCallsInHalfOpenState %>
<%_     } _%>
<%_   }); _%>
<%_ } _%>
  retry:
    configs:
      default:
        maxAttempts: 3
        waitDuration: 500ms
        retryExceptions:
          - feign.RetryableException
          - java.io.IOException
<%_ if (_retInstances.length > 0) { _%>
    instances:
<%_   _retInstances.forEach(inst => { _%>
      <%- inst.name %>:
        baseConfig: default
<%_     if (inst.retries.maxAttempts != null) { _%>
        maxAttempts: <%- inst.retries.maxAttempts %>
<%_     } _%>
<%_     if (inst.retries.waitDuration != null) { _%>
        waitDuration: <%- inst.retries.waitDuration %>
<%_     } _%>
<%_   }); _%>
<%_ } _%>
