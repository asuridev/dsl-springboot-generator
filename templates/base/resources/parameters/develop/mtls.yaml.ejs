integration:
  ssl:
    # Path to the PKCS12 keystore containing the client certificate and private key.
    keystore-path: ${SSL_KEYSTORE_PATH}
    # Password protecting the keystore and private key.
    keystore-password: ${SSL_KEYSTORE_PASSWORD}
    # Path to the PKCS12 truststore containing trusted server CA certificates.
    truststore-path: ${SSL_TRUSTSTORE_PATH}
    # Password protecting the truststore.
    truststore-password: ${SSL_TRUSTSTORE_PASSWORD}
