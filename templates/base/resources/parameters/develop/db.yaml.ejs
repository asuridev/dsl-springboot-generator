spring:
  datasource:
    url: ${DB_URL:jdbc:postgresql://localhost:5432/<%= dbName %>}
    username: ${DB_USERNAME:postgres}
    password: ${DB_PASSWORD:postgres}
    driver-class-name: <%= driverClass %>
  jpa:
    hibernate:
      ddl-auto: update
    show-sql: false
    properties:
      hibernate:
        format_sql: false
        dialect: <%= dialect %>

logging:
  level:
    root: INFO
    <%= packageName %>: DEBUG
