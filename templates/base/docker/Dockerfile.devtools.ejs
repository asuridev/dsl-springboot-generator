<%
const packages = ['bash', 'curl', 'jq', 'netcat-openbsd'];
if (databaseType === 'postgresql') packages.push('postgresql-client');
if (databaseType === 'mysql') packages.push('mysql-client');
if (databaseType === 'mariadb') packages.push('mariadb-client');
if (requestIdempotencyEnabled) packages.push('redis');
if (broker === 'kafka') packages.push('kcat');
const packageLines = packages.map((p, i) =>
  '    ' + p + (i < packages.length - 1 ? ' \\' : '')
).join('\n');
-%>
FROM alpine:3.20

RUN apk add --no-cache \
<%- packageLines %> \
    && echo "devtools ready"
<% if (databaseType === 'sqlserver') { -%>

# go-sqlcmd — statically-linked SQL Server CLI for Fase 3 persistence validation.
RUN apk add --no-cache bzip2 \
    && curl -fsSL https://github.com/microsoft/go-sqlcmd/releases/download/v1.8.2/sqlcmd-linux-amd64.tar.bz2 -o /tmp/sqlcmd.tar.bz2 \
    && tar -xjf /tmp/sqlcmd.tar.bz2 -C /usr/local/bin sqlcmd \
    && chmod +x /usr/local/bin/sqlcmd \
    && rm /tmp/sqlcmd.tar.bz2
<% } -%>
<% if (objectStoragePresent) { -%>

# MinIO client (mc) — for Fase 3 infra validation against the object store.
RUN curl -fsSL https://dl.min.io/client/mc/release/linux-amd64/mc -o /usr/local/bin/mc \
    && chmod +x /usr/local/bin/mc
<% } -%>

WORKDIR /scripts

CMD ["sleep", "infinity"]
