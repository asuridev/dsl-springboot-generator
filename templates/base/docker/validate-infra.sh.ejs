#!/bin/bash
# validate-infra.sh — generated by dsl-springboot-generator
# Usage: ./validate-infra.sh
# Run after: docker compose up -d  OR  podman-compose up -d

SYSTEM="<%= systemName %>"
DB_NAME="<%= databaseName %>"
DB_USER="<%= databaseUsername %>"
DB_PASS="<%= databasePassword %>"
ERRORS=0

# Auto-detect container runtime
if command -v podman &>/dev/null; then
  RUNTIME=podman
  COMPOSE=podman-compose
elif command -v docker &>/dev/null; then
  RUNTIME=docker
  COMPOSE="docker compose"
else
  printf "\033[0;31m[ERROR]\033[0m Neither docker nor podman found in PATH\n"
  exit 1
fi

pass() { printf "\033[0;32m[PASS]\033[0m %s\n" "$1"; }
fail() { printf "\033[0;31m[FAIL]\033[0m %s\n" "$1"; ERRORS=$((ERRORS + 1)); }

check() {
  local name="$1"; shift
  if "$@" >/dev/null 2>&1; then
    pass "$name"
  else
    fail "$name"
  fi
}

echo "Validating infrastructure: ${SYSTEM} (runtime: ${RUNTIME})"
echo "============================================"

<% if (databaseType === 'postgresql') { -%>
check "PostgreSQL connectivity" \
  ${RUNTIME} exec "${SYSTEM}-devtools" \
  bash -c "PGPASSWORD=${DB_PASS} psql -h postgres -U ${DB_USER} -d ${DB_NAME} -c 'SELECT 1' -q -t"

<% } else if (databaseType === 'mysql') { -%>
check "MySQL connectivity" \
  ${RUNTIME} exec "${SYSTEM}-devtools" \
  mysql -h mysql -u "${DB_USER}" "-p${DB_PASS}" "${DB_NAME}" -e "SELECT 1"

<% } -%>
<% if (broker === 'kafka') { -%>
check "Kafka broker reachable" \
  ${RUNTIME} exec "${SYSTEM}-devtools" \
  kcat -b kafka:29092 -L

<% } else if (broker === 'rabbitmq') { -%>
check "RabbitMQ management API" \
  curl -sf -u "guest:guest" "http://localhost:15672/api/healthchecks/node"

<% } -%>
<% if (requestIdempotencyEnabled) { -%>
check "Redis/Valkey PING" \
  ${RUNTIME} exec "${SYSTEM}-devtools" \
  redis-cli -h cache PING

<% } -%>
<% if (authProvider === 'keycloak') { -%>
check "Keycloak realm endpoint" \
  curl -sf "http://localhost:8180/realms/master"

<% } -%>
echo "============================================"
if [ "${ERRORS}" -gt 0 ]; then
  echo "Result: ${ERRORS} check(s) FAILED"
  exit 1
fi
printf "\033[0;32m[PASS]\033[0m All checks passed\n"
