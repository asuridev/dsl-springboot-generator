keycloak:
  image: <%= keycloakImage %>
  container_name: <%= systemName %>-keycloak
  command: start-dev
  environment:
    KC_BOOTSTRAP_ADMIN_USERNAME: admin
    KC_BOOTSTRAP_ADMIN_PASSWORD: admin
    KC_HTTP_PORT: 8080
    KC_HOSTNAME_STRICT: "false"
    KC_HOSTNAME_STRICT_HTTPS: "false"
    KC_HTTP_ENABLED: "true"
  ports:
    - "8180:8080"
  networks:
    - <%= systemName %>-network
