devtools:
  build:
    context: .
    dockerfile: Dockerfile.devtools
  image: <%= systemName %>-devtools
  container_name: <%= systemName %>-devtools
  command: sleep infinity
  depends_on:
<% if (databaseType === 'postgresql') { %>
    - postgres
<% } else if (databaseType === 'mysql') { %>
    - mysql
<% } else if (databaseType === 'sqlserver') { %>
    - sqlserver
<% } else if (databaseType === 'oracle') { %>
    - oracle
<% } %>
<% if (objectStoragePresent) { %>
    - minio
<% } %>
  networks:
    - <%= systemName %>-network
