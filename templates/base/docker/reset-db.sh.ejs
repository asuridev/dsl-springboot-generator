#!/bin/bash
# reset-db.sh — generated by dsl-springboot-generator
# Truncates the domain (and idempotency/outbox) tables so flow validation starts
# from a clean state and the flows' `Given` preconditions hold again.
# The schema (flyway_schema_history included) is preserved — only data is wiped.
# Usage: ./reset-db.sh
# Run while infrastructure is up (after: docker compose up -d / podman-compose up -d).

SYSTEM="<%= systemName %>"
DB_NAME="<%= databaseName %>"
DB_USER="<%= databaseUsername %>"
DB_PASS="<%= databasePassword %>"

# Auto-detect container runtime
if command -v podman &>/dev/null; then
  RUNTIME=podman
elif command -v docker &>/dev/null; then
  RUNTIME=docker
else
  printf "\033[0;31m[ERROR]\033[0m Neither docker nor podman found in PATH\n"
  exit 1
fi

pass() { printf "\033[0;32m[PASS]\033[0m %s\n" "$1"; }
fail() { printf "\033[0;31m[FAIL]\033[0m %s\n" "$1"; }

echo "Resetting database state: ${SYSTEM} (runtime: ${RUNTIME})"
echo "Tables: <%= tables.join(', ') %>"
echo "============================================"

run_sql() {
<% if (databaseType === 'postgresql') { -%>
  ${RUNTIME} exec -i "${SYSTEM}-devtools" \
    bash -c "PGPASSWORD=${DB_PASS} psql -h postgres -U ${DB_USER} -d ${DB_NAME} -v ON_ERROR_STOP=1 -q"
<% } else if (databaseType === 'mysql') { -%>
  ${RUNTIME} exec -i "${SYSTEM}-devtools" \
    mysql -h mysql -u "${DB_USER}" "-p${DB_PASS}" "${DB_NAME}"
<% } else if (databaseType === 'mariadb') { -%>
  ${RUNTIME} exec -i "${SYSTEM}-devtools" \
    mariadb -h mariadb -u "${DB_USER}" "-p${DB_PASS}" "${DB_NAME}"
<% } else if (databaseType === 'sqlserver') { -%>
  ${RUNTIME} exec -i "${SYSTEM}-devtools" \
    sqlcmd -S sqlserver,1433 -U "${DB_USER}" -P "${DB_PASS}" -d "${DB_NAME}" -C -b
<% } else if (databaseType === 'oracle') { -%>
  ${RUNTIME} exec -i "${SYSTEM}-oracle" \
    bash -c "sqlplus -s ${DB_USER}/${DB_PASS}@//localhost:1521/<%= oracleService %>"
<% } -%>
}

if run_sql <<'SQL'
<% if (databaseType === 'oracle') { -%>
WHENEVER SQLERROR EXIT SQL.SQLCODE
<% } -%>
<%- truncateStatements.join('\n') %>
<% if (databaseType === 'oracle') { -%>
COMMIT;
EXIT;
<% } -%>
SQL
then
  pass "Database reset (<%= tables.length %> table(s) cleared)"
else
  fail "Database reset failed"
  exit 1
fi
