<%
// MinIO (S3-compatible) object storage + an `mc` init container that creates the
// declared buckets and opens anonymous download on the public-url ones.
// derived_from: infrastructure.objectStorage[]
const user = '${MINIO_ROOT_USER:-minioadmin}';
const pass = '${MINIO_ROOT_PASSWORD:-minioadmin}';
const mcLines = [];
mcLines.push('mc alias set local http://minio:9000 ' + user + ' ' + pass + ';');
stores.forEach(function (store) {
  mcLines.push('mc mb -p local/' + store.name + ' || true;');
  if (store.urlAccess === 'public-url') {
    mcLines.push('mc anonymous set download local/' + store.name + ';');
  }
});
mcLines.push('echo minio-init done;');
const entrypointBody = mcLines.map(function (l) { return '      ' + l; }).join('\n');
-%>
minio:
  image: <%= minioImage %>
  container_name: <%= systemName %>-minio
  command: server /data --console-address ":9001"
  environment:
    MINIO_ROOT_USER: ${MINIO_ROOT_USER:-minioadmin}
    MINIO_ROOT_PASSWORD: ${MINIO_ROOT_PASSWORD:-minioadmin}
  ports:
    - "9000:9000"
    - "9001:9001"
  volumes:
    - <%= systemName %>-minio-data:/data
  healthcheck:
    test: ["CMD", "mc", "ready", "local"]
    interval: 10s
    timeout: 5s
    retries: 5
  networks:
    - <%= systemName %>-network
minio-createbuckets:
  image: <%= minioClientImage %>
  container_name: <%= systemName %>-minio-init
  depends_on:
    - minio
  entrypoint: >
    /bin/sh -c "
      until (mc alias set local http://minio:9000 ${MINIO_ROOT_USER:-minioadmin} ${MINIO_ROOT_PASSWORD:-minioadmin}) do echo waiting for minio; sleep 2; done;
<%- entrypointBody %>
    "
  networks:
    - <%= systemName %>-network
