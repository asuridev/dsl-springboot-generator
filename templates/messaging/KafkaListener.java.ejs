package <%= packageName %>.<%= moduleName %>.infrastructure.kafkaListener;

import <%= packageName %>.<%= moduleName %>.application.commands.<%= commandClassName %>;
import <%= packageName %>.shared.infrastructure.configurations.useCaseConfig.UseCaseMediator;
import <%= packageName %>.shared.infrastructure.eventEnvelope.EventEnvelope;
<% if (consumerIdempotencyEnabled) { %>import <%= packageName %>.shared.infrastructure.idempotency.IdempotencyGuard;
<% } %><% if (sagasEnabled) { %>import <%= packageName %>.shared.infrastructure.correlation.CorrelationContext;
<% } %><% if (sagasEnabled && sagaSteps && sagaSteps.length > 0) { %>import <%= packageName %>.shared.domain.annotations.SagaStep;
<% } %>
import com.fasterxml.jackson.core.JsonProcessingException;
import com.fasterxml.jackson.core.type.TypeReference;
import com.fasterxml.jackson.databind.ObjectMapper;
import org.apache.kafka.clients.consumer.ConsumerRecord;
import org.slf4j.Logger;
import org.slf4j.LoggerFactory;
import org.springframework.kafka.annotation.KafkaListener;
import org.springframework.kafka.support.Acknowledgment;
import org.springframework.stereotype.Component;

import java.util.Map;
<% const hasLists = fields && fields.some(f => f.javaType && f.javaType.startsWith('List')); %>
<% if (hasLists) { %>import java.util.List;
<% } %>
<% const needsBigDecimal = fields && fields.some(f => f.javaType === 'BigDecimal'); %>
<% const needsLocalDate  = fields && fields.some(f => ['LocalDate','LocalDateTime','LocalTime'].includes(f.javaType)); %>
<% const needsInstant    = fields && fields.some(f => f.javaType === 'Instant'); %>
<% const _hasEarlyId     = typeof hasEarlyIdentityId !== 'undefined' && hasEarlyIdentityId; %>
<% const needsUUID       = _hasEarlyId || (fields && fields.some(f => f.javaType === 'UUID')); %>
<% if (needsBigDecimal) { %>import java.math.BigDecimal;
<% } %><% if (needsLocalDate) { %>import java.time.LocalDate;
import java.time.LocalDateTime;
import java.time.LocalTime;
<% } %><% if (needsInstant) { %>import java.time.Instant;
<% } %><% if (needsUUID) { %>import java.util.UUID;
<% } %><%
// GAP-1: collect imports for custom domain types (VOs, Enums, EventDtos).
// GAP-2: collect inner-type imports for List<StandardType> fields (e.g. List<UUID>,
//         List<Instant>) — these are not caught by the needsXxx checks above because
//         those checks test f.javaType === 'UUID', not f.javaType === 'List<UUID>'.
const _handledKafkaImports = new Set([
  'java.util.List', 'java.util.Map', 'java.util.UUID',
  'java.math.BigDecimal', 'java.time.LocalDate', 'java.time.LocalDateTime',
  'java.time.LocalTime', 'java.time.Instant', 'java.time.Duration',
  'java.net.URI',
]);
const _kafkaDomainImports = new Set();
const _kafkaListInnerImports = new Set();
(fields || []).forEach(f => {
  // Custom domain type (VO, Enum, EventDto): importHint not in standard set
  if (f.importHint && !_handledKafkaImports.has(f.importHint)) _kafkaDomainImports.add(f.importHint);
  // List<T> inner type: innerImportHint exists when inner is a custom or standard type
  if (f.innerImportHint) {
    if (_handledKafkaImports.has(f.innerImportHint)) {
      // Standard inner type (e.g. java.util.UUID for List<UUID>) — not caught by needsXxx
      _kafkaListInnerImports.add(f.innerImportHint);
    } else {
      _kafkaDomainImports.add(f.innerImportHint);
    }
  }
});
%>
<% [..._kafkaListInnerImports].sort().forEach(imp => { %>import <%= imp %>;
<% }); %><% [..._kafkaDomainImports].sort().forEach(imp => { %>import <%= imp %>;
<% }); %>
/**
 * Kafka listener for topic ${topics.<%= topicKey %>}.
 * Consumes events produced by: <%= producer %>.
 * Dispatches to use case: <%= useCase %>.
 * derived_from: domainEvents.consumed.<%= eventName %>
 */
@Component("<%= moduleName %>.<%= listenerClassName %>")
public class <%= listenerClassName %> {

    private static final Logger log = LoggerFactory.getLogger(<%= listenerClassName %>.class);

    private final UseCaseMediator useCaseMediator;
    private final ObjectMapper objectMapper;
<% if (consumerIdempotencyEnabled) { %>    private final IdempotencyGuard idempotencyGuard;
    private static final String HANDLER_ID = "<%= packageName %>.<%= moduleName %>.<%= listenerClassName %>";
<% } %>
    public <%= listenerClassName %>(UseCaseMediator useCaseMediator, ObjectMapper objectMapper<% if (consumerIdempotencyEnabled) { %>, IdempotencyGuard idempotencyGuard<% } %>) {
        this.useCaseMediator = useCaseMediator;
        this.objectMapper = objectMapper;
<% if (consumerIdempotencyEnabled) { %>        this.idempotencyGuard = idempotencyGuard;
<% } %>    }

    @KafkaListener(topics = "${topics.<%= topicKey %>}", groupId = "${spring.kafka.consumer.group-id}")
<% if (sagasEnabled && sagaSteps && sagaSteps.length > 0) { %><% sagaSteps.forEach(s => { %>    @SagaStep(saga = "<%= s.saga %>", order = <%= s.order %>, event = "<%= eventName %>", role = SagaStep.Role.<%= s.role %>)
<% }); %><% } %>    public void handle(ConsumerRecord<String, String> record, Acknowledgment acknowledgment) {
        EventEnvelope<Map<String, Object>> event;
        try {
            event = objectMapper.readValue(
                    record.value(),
                    new TypeReference<EventEnvelope<Map<String, Object>>>() {});
        } catch (JsonProcessingException e) {
            log.error("Fatal deserialization error — skipping message: {}", e.getMessage());
            acknowledgment.acknowledge();
            return;
        }
<% if (sagasEnabled) { %>
        // derived_from: system.yaml#/sagas — propagate correlationId across hops
        String correlationId = event.metadata() != null ? event.metadata().correlationId() : null;
        CorrelationContext.set(correlationId);
<% } %><% if (consumerIdempotencyEnabled) { %>
        // derived_from: system.yaml#/infrastructure/reliability/consumerIdempotency
        String eventId = event.metadata() != null ? event.metadata().eventId() : null;
        if (eventId != null && !idempotencyGuard.tryRecord(HANDLER_ID, eventId)) {
            log.debug("Duplicate eventId={} for handler={} — acknowledging without dispatch", eventId, HANDLER_ID);
            acknowledgment.acknowledge();
            return;
        }
<% } %>

<% (fields || []).forEach(f => { %>
<%   const listMatch = f.javaType && f.javaType.match(/^List<(.+)>$/); %>
<%   if (listMatch) { %>
        <%- f.javaType %> <%= f.name %> = objectMapper.convertValue(
                event.data().get("<%= f.name %>"),
                objectMapper.getTypeFactory().constructCollectionType(List.class, <%= listMatch[1] %>.class));
<%   } else { %>
        <%- f.javaType %> <%= f.name %> = objectMapper.convertValue(event.data().get("<%= f.name %>"), <%- f.javaType %>.class);
<%   } %>
<% }); %>
        try {
<% if (_hasEarlyId) { %>
            // Early-identity create: the command carries the aggregate id as its first
            // (@JsonIgnore) component. No HTTP edge generates it here, so the listener
            // assigns it. Phase 3 may derive it deterministically from the payload.
            UUID id = UUID.randomUUID();
<% } %>
            useCaseMediator.dispatch(new <%= commandClassName %>(
<% const _ctorArgs = _hasEarlyId ? ['id', ...(fields || []).map(f => f.name)] : (fields || []).map(f => f.name); %>
<% _ctorArgs.forEach((argName, i) => { %>
                    <%= argName %><%= i < _ctorArgs.length - 1 ? ',' : '' %>
<% }); %>
            ));
            acknowledgment.acknowledge();
        } catch (Exception e) {
            log.error("Error dispatching <%= commandClassName %>: {}", e.getMessage(), e);
            // Do not acknowledge — allow retry according to consumer configuration
<% if (sagasEnabled) { %>        } finally {
            CorrelationContext.clear();
<% } %>        }
    }
}
