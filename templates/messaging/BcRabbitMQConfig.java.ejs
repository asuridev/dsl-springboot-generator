package <%= packageName %>.<%= moduleName %>.infrastructure.adapters.rabbitmqMessageBroker;

<% if (consumersByProducer.length > 0) { %>
import org.springframework.amqp.core.Binding;
import org.springframework.amqp.core.BindingBuilder;
import org.springframework.amqp.core.Queue;
import org.springframework.amqp.core.QueueBuilder;
<% } %>
import org.springframework.amqp.core.TopicExchange;
import org.springframework.beans.factory.annotation.Value;
import org.springframework.context.annotation.Bean;
import org.springframework.context.annotation.Configuration;

/**
 * RabbitMQ topology configuration for the <%= moduleName %> bounded context.
 *
 * Declares all exchanges, queues, dead-letter exchanges (DLX), dead-letter queues (DLQ)
 * and bindings needed by this BC. Values are resolved at runtime from
 * parameters/{env}/rabbitmq.yaml via @Value — no hardcoded strings.
 *
 * derived_from: domainEvents (published + consumed)
 */
@Configuration
public class <%= modulePascalCase %>RabbitMQConfig {

<% if (publishedEvents.length > 0) { %>
    // ─── Publisher exchange for <%= moduleName %> ──────────────────────────────────────

    @Value("${exchanges.<%= moduleName %>}")
    private String <%= moduleCamelCase %>ExchangeName;

    @Bean
    public TopicExchange <%= moduleCamelCase %>Exchange() {
        return new TopicExchange(<%= moduleCamelCase %>ExchangeName, true, false);
    }

    @Bean
    public TopicExchange <%= moduleCamelCase %>DlxExchange() {
        return new TopicExchange(<%= moduleCamelCase %>ExchangeName + ".dlx", true, false);
    }
    // Consumers declare their own queues bound to this exchange — the publisher BC
    // does not declare queues for its own events. See consumersByProducer section below.

<% } %>
<% for (const producerEntry of consumersByProducer) { %>
    // ─── Consumer: events from <%= producerEntry.producerBc %> ──────────────────────────────────────
    // Bean names are prefixed with the owning BC (<%= moduleCamelCase %>) to avoid collisions
    // when multiple BCs consume from the same producer exchange.

    @Value("${exchanges.<%= producerEntry.producerBc %>}")
    private String <%= moduleCamelCase %>_<%= producerEntry.producerCamel %>ExchangeName;

    @Bean("<%= moduleCamelCase %>_<%= producerEntry.producerCamel %>Exchange")
    public TopicExchange <%= moduleCamelCase %>_<%= producerEntry.producerCamel %>Exchange() {
        return new TopicExchange(<%= moduleCamelCase %>_<%= producerEntry.producerCamel %>ExchangeName, true, false);
    }

    @Bean("<%= moduleCamelCase %>_<%= producerEntry.producerCamel %>DlxExchange")
    public TopicExchange <%= moduleCamelCase %>_<%= producerEntry.producerCamel %>DlxExchange() {
        return new TopicExchange(<%= moduleCamelCase %>_<%= producerEntry.producerCamel %>ExchangeName + ".dlx", true, false);
    }

<% for (const event of producerEntry.events) { %>
    // ─── <%= event.name %> (from <%= producerEntry.producerBc %>) ──────────────────────────────────

    @Value("${queues.<%= event.queueKey %>}")
    private String <%= event.fieldName %>QueueName;

    @Value("${routing-keys.<%= event.queueKey %>}")
    private String <%= event.fieldName %>RoutingKey;

    @Bean
    public Queue <%= event.fieldName %>Queue() {
        return QueueBuilder.durable(<%= event.fieldName %>QueueName)
                .withArgument("x-dead-letter-exchange", <%= moduleCamelCase %>_<%= producerEntry.producerCamel %>ExchangeName + ".dlx")
<% if (event.dlqRoutingKey) { %>                .withArgument("x-dead-letter-routing-key", "<%= event.dlqRoutingKey %>")
<% } %><% if (event.deliveryLimit) { %>                .withArgument("x-delivery-limit", <%= event.deliveryLimit %>)
<% } %><% if (event.messageTtlMs) { %>                .withArgument("x-message-ttl", <%= event.messageTtlMs %>)
<% } %>                .build();
    }

    @Bean
    public Binding <%= event.fieldName %>Binding() {
        return BindingBuilder
                .bind(<%= event.fieldName %>Queue())
                .to(<%= moduleCamelCase %>_<%= producerEntry.producerCamel %>Exchange())
                .with(<%= event.fieldName %>RoutingKey);
    }

    @Bean
    public Queue <%= event.fieldName %>Dlq() {
        return QueueBuilder.durable(<% if (event.dlqQueueName) { %>"<%= event.dlqQueueName %>"<% } else { %><%= event.fieldName %>QueueName + ".dlq"<% } %>).build();
    }

    @Bean
    public Binding <%= event.fieldName %>DlqBinding() {
        return BindingBuilder
                .bind(<%= event.fieldName %>Dlq())
                .to(<%= moduleCamelCase %>_<%= producerEntry.producerCamel %>DlxExchange())
                .with(<% if (event.dlqRoutingKey) { %>"<%= event.dlqRoutingKey %>"<% } else { %><%= event.fieldName %>RoutingKey<% } %>);
    }

<% } %>
<% } %>
}
