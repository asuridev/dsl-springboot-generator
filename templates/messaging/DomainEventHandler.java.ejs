package <%= packageName %>.<%= bc %>.application.usecases;

<% if (outboxEnabled) { %>
import <%= packageName %>.shared.infrastructure.eventEnvelope.EventEnvelope;
import <%= packageName %>.shared.infrastructure.outbox.OutboxEventJpa;
import <%= packageName %>.shared.infrastructure.outbox.OutboxEventJpaRepository;
import com.fasterxml.jackson.core.JsonProcessingException;
import com.fasterxml.jackson.databind.ObjectMapper;
import org.slf4j.MDC;
import org.springframework.beans.factory.annotation.Value;
import org.springframework.context.event.EventListener;
import java.time.Instant;
import java.util.UUID;
<% } else { %>
import <%= packageName %>.<%= bc %>.application.ports.MessageBroker;
import org.springframework.transaction.event.TransactionPhase;
import org.springframework.transaction.event.TransactionalEventListener;
<% } %>
import <%= packageName %>.shared.domain.annotations.ApplicationComponent;
<% const _bcHasSagaSteps = sagasEnabled && (domainEvents || []).some(e => e.sagaSteps && e.sagaSteps.length > 0); %>
<% if (_bcHasSagaSteps) { %>import <%= packageName %>.shared.domain.annotations.SagaStep;
<% } %><% domainEvents.forEach(event => { %>
import <%= packageName %>.<%= bc %>.application.events.<%= event.integrationEventClassName %>;
import <%= packageName %>.<%= bc %>.domain.events.<%= event.name %>Event;
<% }); %>

/**
 * <%= bcPascal %>DomainEventHandler — Domain Event Bridge
 *
<% if (outboxEnabled) { %>
 * derived_from: system.yaml#/infrastructure/reliability/outbox
 *
 * Outbox mode is enabled. Each domain event is captured by a regular
 * {@code @EventListener} (synchronous, runs inside the publishing transaction)
 * and persisted as a row in {@code outbox_event}. The shared {@code OutboxRelay}
 * scheduler forwards the row to the broker after the transaction commits.
 *
 * This guarantees atomicity between aggregate persistence and event capture:
 * if the database transaction rolls back, the outbox row is rolled back too.
<% } else { %>
 * Connects the internal Spring event bus (ApplicationEventPublisher) with
 * the external messaging port ({@link MessageBroker}).
 *
 * AFTER_COMMIT guarantees that external events are published only when the
 * database transaction committed successfully, preventing ghost events from
 * rolled-back operations.
<% } %>
 */
@ApplicationComponent
public class <%= bcPascal %>DomainEventHandler {

<% if (outboxEnabled) { %>
    private final OutboxEventJpaRepository outboxRepository;
    private final ObjectMapper objectMapper;

<% if (broker === 'kafka') { %>
<% domainEvents.forEach(event => { %>
    @Value("${topics.<%= event.topicNameKebab %>}")
    private String <%= event.topicNameCamel %>Topic;
<% }); %>
<% } else { %>
    @Value("${exchanges.<%= bc %>:<%= bc %>.events}")
    private String exchange;
<% domainEvents.forEach(event => { %>
    @Value("${routing-keys.<%= event.topicNameKebab %>:<%= bc %>.<%= event.topicNameKebab %>}")
    private String <%= event.topicNameCamel %>RoutingKey;
<% }); %>
<% } %>

    public <%= bcPascal %>DomainEventHandler(OutboxEventJpaRepository outboxRepository, ObjectMapper objectMapper) {
        this.outboxRepository = outboxRepository;
        this.objectMapper = objectMapper;
    }
<% domainEvents.forEach(event => { %>
    /**
     * Handles {@link <%= event.name %>Event} synchronously inside the publishing transaction
     * and persists an outbox row for asynchronous broker delivery.
     * derived_from: domainEvents.published.<%= event.name %>
     */
    @EventListener
<% if (sagasEnabled && event.sagaSteps && event.sagaSteps.length > 0) { %><% event.sagaSteps.forEach(s => { %>    @SagaStep(saga = "<%= s.saga %>", order = <%= s.order %>, event = "<%= event.name %>", role = SagaStep.Role.<%= s.role %>)
<% }); %><% } %>    public void on<%= event.name %>Event(<%= event.name %>Event event) {
        <%= event.integrationEventClassName %> integrationEvent = new <%= event.integrationEventClassName %>(
<% if (event.metadataEnabled) { %>                event.metadata()<% if (event.fields.length > 0) { %>,<% } %>
<% } %><% event.fields.forEach((f, idx) => { %>
                event.<%= f.name %>()<%= idx < event.fields.length - 1 ? ',' : '' %>
<% }); %>
        );
        EventEnvelope<<%= event.integrationEventClassName %>> envelope = EventEnvelope.of(
            <% if (broker === 'kafka') { %><%= event.topicNameCamel %>Topic<% } else { %><%= event.topicNameCamel %>RoutingKey<% } %>,
            integrationEvent,
            MDC.get("correlationId")
        );
        try {
            outboxRepository.save(OutboxEventJpa.builder()
                .id(UUID.randomUUID())
<% if (broker === 'kafka') { %>
                .destination(<%= event.topicNameCamel %>Topic)
                .routingKey(null)<% } else { %>
                .destination(exchange)
                .routingKey(<%= event.topicNameCamel %>RoutingKey)<% } %>
                .eventType("<%= event.integrationEventClassName %>")
                .payload(objectMapper.writeValueAsString(envelope))
                .createdAt(Instant.now())
                .attempts(0)
                .build());
        } catch (JsonProcessingException e) {
            throw new IllegalStateException("Failed to serialize <%= event.integrationEventClassName %>", e);
        }
    }
<% }); %>
<% } else { %>
    private final MessageBroker messageBroker;

    public <%= bcPascal %>DomainEventHandler(MessageBroker messageBroker) {
        this.messageBroker = messageBroker;
    }
<% domainEvents.forEach(event => { %>
    /**
     * Handles {@link <%= event.name %>Event} after the wrapping transaction commits.
     * derived_from: domainEvents.published.<%= event.name %>
     */
    @TransactionalEventListener(phase = TransactionPhase.AFTER_COMMIT)
<% if (sagasEnabled && event.sagaSteps && event.sagaSteps.length > 0) { %><% event.sagaSteps.forEach(s => { %>    @SagaStep(saga = "<%= s.saga %>", order = <%= s.order %>, event = "<%= event.name %>", role = SagaStep.Role.<%= s.role %>)
<% }); %><% } %>    public void on<%= event.name %>Event(<%= event.name %>Event event) {
        messageBroker.publish<%= event.integrationEventClassName %>(
            new <%= event.integrationEventClassName %>(
<% if (event.metadataEnabled) { %>                event.metadata()<% if (event.fields.length > 0) { %>,<% } %>
<% } %><% event.fields.forEach((f, idx) => { %>
                event.<%= f.name %>()<%= idx < event.fields.length - 1 ? ',' : '' %>
<% }); %>
            )
        );
    }
<% }); %>
<% } %>
}
