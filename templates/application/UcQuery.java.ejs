package <%= packageName %>.<%= moduleName %>.application.queries;

import <%= packageName %>.shared.domain.interfaces.Query;
<% if (imports && imports.length > 0) { %>
<% imports.forEach(imp => { %>import <%- imp %>;
<% }); %>
<% } %>
public record <%= useCaseName %>Query(
<%- fields.map((f, i) => {
  const ann = (f.annotations && f.annotations.length > 0) ? f.annotations.join(' ') + ' ' : '';
  const comma = i < fields.length - 1 ? ',' : '';
  return '    ' + ann + f.type + ' ' + f.name + comma;
}).join('\n') %>
) implements Query<<%- returnType %>> {
}
