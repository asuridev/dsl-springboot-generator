<% fkRepos.forEach(fk => { %>    private final <%= fk.repoName %> <%= fk.repoFieldName %>;
<% }); %>
<% } %>
<% if (needsMapper) { %>    private final <%= mapperName %> <%= mapperFieldName %>;
<% } %>

    public <%= useCaseName %>CommandHandler(
