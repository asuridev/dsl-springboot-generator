<% }); %><% } %><% if (needsMapper) { %>
            <%= mapperName %> <%= mapperFieldName %><% } %>) {
        this.<%= repoFieldName %> = <%= repoFieldName %>;
<% if (fkRepos && fkRepos.length > 0) { %>
<% fkRepos.forEach(fk => { %>        this.<%= fk.repoFieldName %> = <%= fk.repoFieldName %>;
<% }); %>
<% } %>
<% if (needsMapper) { %>        this.<%= mapperFieldName %> = <%= mapperFieldName %>;
<% } %>    }

    @Override
    @Transactional
    @LogExceptions
    public void handle(<%= useCaseName %>Command command) {
<% if (implementation === 'scaffold') { %>
        // TODO: implement business logic — ver <%= moduleName %>-flows.md
        throw new UnsupportedOperationException("Not implemented yet");
<% } else { %>
<%- body %>
<% } %>
    }
}
