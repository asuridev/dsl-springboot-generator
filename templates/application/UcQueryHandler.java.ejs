package <%= packageName %>.<%= moduleName %>.application.usecases;

import <%= packageName %>.<%= moduleName %>.application.queries.<%= useCaseName %>Query;
import <%= packageName %>.<%= moduleName %>.domain.repository.<%= repoName %>;
import <%= packageName %>.<%= moduleName %>.application.mappers.<%= mapperName %>;
import <%= packageName %>.shared.domain.annotations.ApplicationComponent;
import <%= packageName %>.shared.domain.annotations.LogExceptions;
import <%= packageName %>.shared.domain.interfaces.QueryHandler;
<% if (imports && imports.length > 0) { %>
<% imports.forEach(imp => { %>import <%- imp %>;
<% }); %>
<% } %>
import org.springframework.transaction.annotation.Transactional;

<% if (description && description.trim()) { %>/**
<% description.split(/\n/).forEach(function(line) { %> * <%- line %>
<% }); %> *
 * derived_from: useCases[<%= useCaseId %>]
 */
<% } else { %>// derived_from: useCases[<%= useCaseId %>]
<% } %>@ApplicationComponent
public class <%= useCaseName %>QueryHandler implements QueryHandler<<%= useCaseName %>Query, <%- returnType %>> {

    private final <%= repoName %> <%= repoFieldName %>;
    private final <%= mapperName %> <%= mapperFieldName %>;

    public <%= useCaseName %>QueryHandler(<%= repoName %> <%= repoFieldName %>, <%= mapperName %> <%= mapperFieldName %>) {
        this.<%= repoFieldName %> = <%= repoFieldName %>;
        this.<%= mapperFieldName %> = <%= mapperFieldName %>;
    }

    @Override
    @Transactional(readOnly = true)
    @LogExceptions
    public <%- returnType %> handle(<%= useCaseName %>Query query) {
<% if (validations && validations.length > 0) { %>
        // [G20] cross-field validations — derived_from useCases[<%= useCaseId %>].validations[]
<% validations.forEach(function(v) { %><% if (v.throwable && v.errorClass) { %>        // derived_from: validations[<%= v.id %>] — errors[<%= v.errorCode %>]
        if (!(<%- v.expression %>)) {
            throw new <%= v.errorClass %>();
        }
<% } else { %>        // TODO useCase(<%= useCaseId %>, validations[<%= v.id %>]): enforce expression `<%= v.expression %>` and throw <%= v.errorClass ? 'new ' + v.errorClass + '()' : 'the exception bound to errorCode "' + v.errorCode + '"' %> on violation.<% if (v.description && v.description.trim()) { %> // <%- v.description.trim() %><% } %>

<% } %><% }); %><% } %><% if (implementation === 'scaffold') { %>
        // TODO: implement business logic — ver <%= moduleName %>-flows.md
        throw new UnsupportedOperationException("Not implemented yet");
<% } else { %>
<%- body %>
<% } %>
    }
}
