package <%= packageName %>.<%= moduleName %>.application.commands;

<% if (returnType) { %>import <%= packageName %>.shared.domain.interfaces.ReturningCommand;
<% } else { %>import <%= packageName %>.shared.domain.interfaces.Command;
<% } %>
<% if (imports && imports.length > 0) { %>
<% imports.forEach(imp => { %>import <%- imp %>;
<% }); %>
<% } %>
<% if (description && description.trim()) { %>/**
<% description.split(/\n/).forEach(function(line) { %> * <%- line %>
<% }); %> *
 * derived_from: useCases[<%= useCaseId %>]
 */
<% } else { %>// derived_from: useCases[<%= useCaseId %>]
<% } %>public record <%= useCaseName %>Command(
<%- fields.map((f, i) => {
  const ann = (f.annotations && f.annotations.length > 0) ? f.annotations.join(' ') + ' ' : '';
  const comma = i < fields.length - 1 ? ',' : '';
  return '    ' + ann + f.type + ' ' + f.name + comma;
}).join('\n') %>
) implements <% if (returnType) { %>ReturningCommand<<%- returnType %>><% } else { %>Command<% } %> {
}

