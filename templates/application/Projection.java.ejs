 */
<% } %>
// derived_from: <%= derivedFrom %>
<% if (usedBy && usedBy.length > 0) { %>// used_by: <%= usedBy.map(u => 'useCase:' + u).join(', ') %>
<% } %>
<% (classAnnotations || []).forEach(a => { %><%- a %>
<% }); %>
public record <%= projectionName %>(
<%- fields.map((f, i) => {
  const ann = (f.annotations && f.annotations.length > 0) ? f.annotations.join(' ') + ' ' : '';
  const comma = i < fields.length - 1 ? ',' : '';
  return '    ' + ann + f.type + ' ' + f.name + comma;
}).join('\n') %>
) {
