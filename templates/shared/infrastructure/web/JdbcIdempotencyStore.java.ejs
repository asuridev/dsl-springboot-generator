package <%= packageName %>.shared.infrastructure.web;

import java.time.Duration;
import java.time.Instant;
import org.springframework.dao.DataIntegrityViolationException;
import org.springframework.stereotype.Component;
import org.springframework.transaction.annotation.Transactional;

/**
 * Database-backed {@link IdempotencyStore} implementation using the three-state
 * protocol (ABSENT → PENDING → COMPLETE). Persistence is delegated to
 * {@link IdempotencyRequestJpaRepository}; the PENDING state is stored as a
 * row with {@code responseStatus = 0}, and COMPLETE overwrites it with the
 * actual response. Uniqueness on the request key is enforced by the
 * primary-key constraint, making {@link #claim} naturally atomic.
 *
 * derived_from: useCases[*].idempotency.storage = database
 */
@Component
public class JdbcIdempotencyStore implements IdempotencyStore {

    private final IdempotencyRequestJpaRepository repository;

    public JdbcIdempotencyStore(IdempotencyRequestJpaRepository repository) {
        this.repository = repository;
    }

    @Override
    @Transactional(readOnly = true)
    public FindResult find(String key) {
        return repository.findById(key)
            .map(row -> {
                if (row.getExpiresAt() != null && row.getExpiresAt().isBefore(Instant.now())) {
                    return new FindResult(State.ABSENT, null);
                }
                if (row.getResponseStatus() == 0) {
                    return new FindResult(State.PENDING, null);
                }
                return new FindResult(State.COMPLETE,
                    new StoredResponse(row.getResponseStatus(), row.getResponseBody(), row.getResponseContentType()));
            })
            .orElse(new FindResult(State.ABSENT, null));
    }

    @Override
    @Transactional
    public boolean claim(String key, Duration ttl) {
        IdempotencyRequestJpa pending = IdempotencyRequestJpa.builder()
            .key(key)
            .requestHash(null)
            .responseStatus(0)   // sentinel: 0 = PENDING
            .responseBody(null)
            .responseContentType(null)
            .expiresAt(Instant.now().plus(ttl))
            .build();
        try {
            repository.save(pending);
            return true;
        } catch (DataIntegrityViolationException duplicate) {
            // Another caller claimed the slot first.
            return false;
        }
    }

    @Override
    @Transactional
    public void complete(String key, String requestHash, StoredResponse response, Duration ttl) {
        repository.findById(key).ifPresent(row -> {
            row.setRequestHash(requestHash);
            row.setResponseStatus(response.status());
            row.setResponseBody(response.body());
            row.setResponseContentType(response.contentType());
            row.setExpiresAt(Instant.now().plus(ttl));
            repository.save(row);
        });
    }

    @Override
    @Transactional
    public void release(String key) {
        repository.deleteById(key);
    }
}
