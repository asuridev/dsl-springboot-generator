package <%= packageName %>.shared.infrastructure.web;

import jakarta.persistence.Column;
import jakarta.persistence.Entity;
import jakarta.persistence.Id;
import jakarta.persistence.Lob;
import jakarta.persistence.Table;
import java.time.Instant;
import lombok.AllArgsConstructor;
import lombok.Builder;
import lombok.Getter;
import lombok.NoArgsConstructor;
import lombok.Setter;

/**
 * JPA row backing {@link JdbcIdempotencyStore}. The primary key is the raw
 * request key sent by the client (header value), which provides the
 * uniqueness guarantee required for atomic save-if-absent semantics.
 *
 * derived_from: useCases[*].idempotency.storage = database
 */
@Entity
@Table(name = "idempotency_request")
@Getter
@Setter
@NoArgsConstructor
@AllArgsConstructor
@Builder
public class IdempotencyRequestJpa {

    @Id
    @Column(name = "key", length = 255, nullable = false)
    private String key;

    @Column(name = "request_hash", length = 128, nullable = false)
    private String requestHash;

    @Column(name = "response_status", nullable = false)
    private int responseStatus;

    @Lob
    @Column(name = "response_body")
    private byte[] responseBody;

    @Column(name = "response_content_type", length = 128)
    private String responseContentType;

    @Column(name = "expires_at", nullable = false)
    private Instant expiresAt;
}
