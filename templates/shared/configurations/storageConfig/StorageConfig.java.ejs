package <%= packageName %>.shared.infrastructure.configurations.storageConfig;

import java.net.URI;

import org.springframework.beans.factory.annotation.Value;
import org.springframework.context.annotation.Bean;
import org.springframework.context.annotation.Configuration;

import software.amazon.awssdk.auth.credentials.AwsBasicCredentials;
import software.amazon.awssdk.auth.credentials.StaticCredentialsProvider;
import software.amazon.awssdk.regions.Region;
import software.amazon.awssdk.services.s3.S3Client;
import software.amazon.awssdk.services.s3.S3Configuration;
import software.amazon.awssdk.services.s3.presigner.S3Presigner;

/**
 * Provider-agnostic object-storage client beans.
 *
 * derived_from: objectStorage
 *
 * Configured against an S3-compatible endpoint (MinIO by default; swap to AWS
 * S3 / R2 / GCS-XML by changing {@code storage.*} config only — no code change).
 *
 * When {@code storage.endpoint} is set, an endpoint override + path-style
 * addressing are applied (required by MinIO / R2, which lack virtual-host bucket
 * addressing). When {@code storage.endpoint} is blank, the SDK resolves the
 * endpoint natively (real AWS S3: virtual-host style, region-based resolution).
 */
@Configuration
public class StorageConfig {

    @Value("${storage.endpoint:}")
    private String endpoint;

    @Value("${storage.region:us-east-1}")
    private String region;

    @Value("${storage.access-key}")
    private String accessKey;

    @Value("${storage.secret-key}")
    private String secretKey;

    private StaticCredentialsProvider credentials() {
        return StaticCredentialsProvider.create(AwsBasicCredentials.create(accessKey, secretKey));
    }

    @Bean
    public S3Client s3Client() {
        var builder = S3Client.builder()
            .region(Region.of(region))
            .credentialsProvider(credentials());
        if (endpoint != null && !endpoint.isBlank()) {
            // S3-compatible (MinIO / R2): override endpoint + path-style addressing
            builder.endpointOverride(URI.create(endpoint))
                .serviceConfiguration(S3Configuration.builder().pathStyleAccessEnabled(true).build());
        }
        // endpoint blank → AWS S3 native resolution (virtual-host style, by region)
        return builder.build();
    }

    @Bean
    public S3Presigner s3Presigner() {
        var builder = S3Presigner.builder()
            .region(Region.of(region))
            .credentialsProvider(credentials());
        if (endpoint != null && !endpoint.isBlank()) {
            // S3-compatible (MinIO / R2): override endpoint + path-style addressing
            builder.endpointOverride(URI.create(endpoint))
                .serviceConfiguration(S3Configuration.builder().pathStyleAccessEnabled(true).build());
        }
        // endpoint blank → AWS S3 native resolution (virtual-host style, by region)
        return builder.build();
    }
}
