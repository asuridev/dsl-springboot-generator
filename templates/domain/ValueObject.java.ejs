package <%- packageName %>.<%= bc %>.domain.valueobject;
<% imports.forEach(imp => { %>
<%- imp %><% }); %>

/**
 * <%= name %> — Value Object
 * Immutable domain value object (pure Java, no Lombok).
<% if (description) { %> *
 * <%= description.trim().replace(/\n\s*/g, '\n * ') %>
<% } %> *
 * derived_from: <%= traceTag %>
 */
public final class <%= name %> {
<% if (hasEmail) { %>
    private static final Pattern EMAIL_PATTERN = Pattern.compile(
        "^[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}$"
    );
<% } %>
<% fields.forEach(field => { %>
    private final <%- field.javaType %> <%= field.name %>;
<% }); %>
    public <%= name %>(<% fields.forEach((field, idx) => { %><%- field.javaType %> <%= field.name %><%= idx < fields.length - 1 ? ', ' : '' %><% }); %>) {
<% fields.forEach(field => { field.guards.forEach(g => { %><%- g %>
<% }); }); %>
<% fields.forEach(field => { %><%- field.assignment %>
<% }); %>    }
<% if (isMicrotype) { const f = fields[0]; %>
    /** Convenience factory. derived_from: <%= traceTag %> */
    public static <%= name %> of(<%- f.javaType %> <%= f.name %>) {
        return new <%= name %>(<%= f.name %>);
    }
<% } %>
    // ─── Getters ──────────────────────────────────────────────────────────────
<% fields.forEach(field => { %>
    public <%- field.javaType %> get<%= field.pascalName %>() {
        return <%= field.name %>;
    }
<% }); %>
    // ─── Structural equality ──────────────────────────────────────────────────

    @Override
    public boolean equals(Object o) {
        if (this == o) return true;
        if (o == null || getClass() != o.getClass()) return false;
        <%= name %> that = (<%= name %>) o;
<% if (fields.length === 0) { %>        return true;<% } else { %>        return <%- fields.map(f => f.equalsExpr).join(' &&\n               ') %>;<% } %>
    }

    @Override
    public int hashCode() {
        return Objects.hash(<%= fields.map(f => f.name).join(', ') %>);
    }

    @Override
    public String toString() {
        return "<%= name %>{" +
<% fields.forEach((field, idx) => { %>               "<%= idx > 0 ? ', ' : '' %><%= field.name %>=" + <%= field.name %> +
<% }); %>               '}';
    }
<% if (hasDecimal) { %>
    private static boolean eqDecimal(java.math.BigDecimal a, java.math.BigDecimal b) {
        if (a == b) return true;
        if (a == null || b == null) return false;
        return a.compareTo(b) == 0;
    }
<% } %>
}
