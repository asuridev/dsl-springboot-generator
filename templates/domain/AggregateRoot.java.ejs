package <%- packageName %>.<%= bc %>.domain.aggregate;
<% imports.forEach(imp => { %>
<%- imp %><% }); %>

/**
 * <%= name %> — Aggregate Root
 * Pure domain class (no Lombok, no public setters).
<% if (description) { %> *
 * <%= description.trim().replace(/\n\s*/g, '\n * ') %>
<% } %> */
public class <%= name %> {
<% if (hasDomainEvents) { %>
    // ─── Domain Events ────────────────────────────────────────────────────────

    private final List<DomainEvent> _domainEvents = new ArrayList<>();

    protected void raise(DomainEvent event) {
        _domainEvents.add(event);
    }

    public List<DomainEvent> pullDomainEvents() {
        List<DomainEvent> events = Collections.unmodifiableList(new ArrayList<>(_domainEvents));
        _domainEvents.clear();
        return events;
    }
<% } %>
    // ─── Fields ───────────────────────────────────────────────────────────────
    private final UUID id;
<% fields.forEach(field => { %>    private <%- field.javaType %> <%= field.name %><% if (field.isList) { %> = new ArrayList<>()<% } %>;
<% }); %>
<% childEntities.forEach(ce => { %>    private <%- ce.javaType %> <%= ce.fieldName %><% if (!ce.isOneToOne) { %> = new ArrayList<>()<% } %>;
<% }); %>
<% if (hasAudit) { %>    private Instant createdAt;
    private Instant updatedAt;
<% } %>
<% if (hasSoftDelete) { %>    private Instant deletedAt;
<% } %>

    // ─── Full constructor (reconstruction from persistence) ───────────────────
    public <%= name %>(<% let _ri = 0; %>UUID id<% _ri++; %><% fields.forEach(field => { %>, <%- field.javaType %> <%= field.name %><% _ri++; %><% }); %><% childEntities.forEach(ce => { %>, <%- ce.javaType %> <%= ce.fieldName %><% _ri++; %><% }); %><% if (hasAudit) { %>, Instant createdAt, Instant updatedAt<% } %><% if (hasSoftDelete) { %>, Instant deletedAt<% } %>) {
        this.id = id;
<% fields.forEach(field => { %>        this.<%= field.name %> = <% if (field.isList) { %>new ArrayList<>(<%= field.name %> != null ? <%= field.name %> : java.util.Collections.emptyList())<% } else { %><%= field.name %><% } %>;
<% }); %>
<% childEntities.forEach(ce => { %>        this.<%= ce.fieldName %> = <% if (ce.isOneToOne) { %><%= ce.fieldName %><% } else { %>new ArrayList<>(<%= ce.fieldName %> != null ? <%= ce.fieldName %> : java.util.Collections.emptyList())<% } %>;
<% }); %>
<% if (hasAudit) { %>        this.createdAt = createdAt;
        this.updatedAt = updatedAt;
<% } %>
<% if (hasSoftDelete) { %>        this.deletedAt = deletedAt;
<% } %>    }
<% if (staticFactory || creationParams.length > 0 || autoInits.length > 0) { %>

    // ─── Creation constructor (new <%= name %>) ───────────────────────────────
    private <%= name %>(<% creationParams.forEach((p, idx) => { %><%- p.javaType %> <%= p.name %><%= idx < creationParams.length - 1 ? ', ' : '' %><% }); %>) {
<% (creationChecks || []).forEach(line => { %>        <%- line %>
<% }); %>        this.id = UUID.randomUUID();
<% creationParams.forEach(p => { %>        this.<%= p.name %> = <% if (p.isList) { %>new ArrayList<>(<%= p.name %> != null ? <%= p.name %> : java.util.Collections.emptyList())<% } else { %><%= p.name %><% } %>;
<% }); %>
<% autoInits.forEach(ai => { %>        this.<%= ai.name %> = <%- ai.value %>;
<% }); %>    }
<% } %>
<% if (staticFactory) { %>

    // ─── Static factory ───────────────────────────────────────────────────────

    /** derived_from: <%= staticFactory.derivedFrom %> */
    public static <%= name %> create(<% staticFactory.params.forEach((p, idx) => { %><%- p.javaType %> <%= p.name %><%= idx < staticFactory.params.length - 1 ? ', ' : '' %><% }); %>) {
<% if (staticFactory.scaffoldRulesComment) { %>        <%- staticFactory.scaffoldRulesComment %>
<% } %>        <%= name %> instance = new <%= name %>(<%= staticFactory.ctorCallArgs %>);<% if (staticFactory.raiseCall) { %>        instance.<%- staticFactory.raiseCall %>
<% } %>        return instance;
    }
<% } %>

    // ─── Getters ──────────────────────────────────────────────────────────────

    public UUID getId() {
        return id;
    }
<% fields.forEach(field => { %>
<% if (!field.hidden) { %>    public <%- field.javaType %> get<%= field.name.charAt(0).toUpperCase() + field.name.slice(1) %>() {
        return <%= field.name %>;
    }
<% } %><% }); %>
<% childEntities.forEach(ce => { %>
    public <%- ce.javaType %> get<%= ce.fieldName.charAt(0).toUpperCase() + ce.fieldName.slice(1) %>() {
        return <% if (ce.isOneToOne) { %><%= ce.fieldName %><% } else { %>java.util.Collections.unmodifiableList(<%= ce.fieldName %>)<% } %>;
    }
<% }); %>
<% if (hasAudit) { %>
    public Instant getCreatedAt() {
        return createdAt;
    }

    public Instant getUpdatedAt() {
        return updatedAt;
    }
<% } %>
<% if (hasSoftDelete) { %>
    public Instant getDeletedAt() {
        return deletedAt;
    }

    public boolean isDeleted() {
        return this.deletedAt != null;
    }
<% } %>
<% if (businessMethods.length > 0) { %>
    // ─── Business methods ─────────────────────────────────────────────────────
<% businessMethods.forEach(method => { %>

    /** derived_from: <%= method.derivedFrom %> */
    public <%- method.returnType %> <%= method.name %>(<% method.params.forEach((p, idx) => { %><%- p.javaType %> <%= p.name %><%= idx < method.params.length - 1 ? ', ' : '' %><% }); %>) {
        <%- method.body %>
    }
<% }); %>
<% } %>
    // ─── Identity equality (S20) ──────────────────────────────────────────────

    @Override
    public boolean equals(Object o) {
        if (this == o) return true;
        if (o == null || getClass() != o.getClass()) return false;
        <%= name %> that = (<%= name %>) o;
        return java.util.Objects.equals(this.id, that.id);
    }

    @Override
    public int hashCode() {
        return java.util.Objects.hash(this.id);
    }

    @Override
    public String toString() {
        return "<%= name %>{id=" + this.id + "}";
    }
}
