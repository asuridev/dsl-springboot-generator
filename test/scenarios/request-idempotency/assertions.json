{
  "src/main/java/com/test/shared/infrastructure/web/RedisIdempotencyStore.java": {
    "_comment": "Redis adapter must be generated (not JdbcIdempotencyStore)",
    "contains": [
      "class RedisIdempotencyStore implements IdempotencyStore",
      "StringRedisTemplate",
      "idempotency:",
      "setIfAbsent",
      "State.COMPLETE",
      "State.PENDING"
    ]
  },
  "src/main/java/com/test/shared/infrastructure/web/IdempotencyStore.java": {
    "_comment": "Interface must expose 3-state protocol",
    "contains": [
      "enum State",
      "ABSENT",
      "PENDING",
      "COMPLETE",
      "record FindResult",
      "boolean claim(",
      "void complete(",
      "void release("
    ],
    "notContains": [
      "saveIfAbsent",
      "Optional<StoredResponse> find"
    ]
  },
  "src/main/java/com/test/shared/infrastructure/web/IdempotencyFilter.java": {
    "_comment": "Filter must use claim/complete/release — no saveIfAbsent",
    "contains": [
      "store.claim(",
      "store.complete(",
      "store.release(",
      "State.COMPLETE",
      "State.PENDING",
      "HttpStatus.CONFLICT"
    ],
    "notContains": [
      "saveIfAbsent",
      "store.find(key).isPresent()"
    ]
  },
  "src/main/java/com/test/shared/infrastructure/web/Idempotent.java": {
    "_comment": "Annotation must still be generated",
    "contains": [
      "@interface Idempotent",
      "String header()",
      "String ttl()"
    ]
  },
  "build.gradle": {
    "_comment": "Redis Spring dependency must appear in build.gradle",
    "contains": [
      "spring-boot-starter-data-redis"
    ],
    "notContains": [
      "flyway"
    ]
  },
  "src/main/resources/parameters/local/redis.yaml": {
    "_comment": "Redis config must be generated for local profile",
    "contains": [
      "spring:",
      "data:",
      "redis:",
      "host: localhost",
      "port: 6379"
    ]
  },
  "src/main/resources/parameters/develop/redis.yaml": {
    "_comment": "Redis config for develop uses env vars",
    "contains": [
      "REDIS_HOST",
      "REDIS_PORT"
    ]
  },
  "src/main/resources/parameters/production/redis.yaml": {
    "_comment": "Redis config for production uses mandatory env vars",
    "contains": [
      "${REDIS_HOST}",
      "${REDIS_PASSWORD}"
    ]
  },
  "docker-compose.yaml": {
    "_comment": "Redis service must be present in docker-compose",
    "contains": [
      "redis:7-alpine",
      "test-idempotency-system-cache"
    ]
  }
}
