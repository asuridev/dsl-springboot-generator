{
  "src/main/java/com/test/orders/infrastructure/persistence/projections/LocalProductViewJpa.java": {
    "_comment": "JPA entity generated from persistent projection. Single @Entity @Table for LocalProductView.",
    "contains": [
      "package com.test.orders.infrastructure.persistence.projections",
      "@Entity",
      "@Table(name = \"proj_local_product_view\")",
      "class LocalProductViewJpa",
      "@Id",
      "UUID productId",
      "String productName",
      "BigDecimal price",
      "Instant lastUpdatedAt",
      "derived_from: bc.orders.projections[LocalProductView]"
    ]
  },

  "src/main/java/com/test/orders/infrastructure/persistence/projections/LocalProductViewJpaRepository.java": {
    "_comment": "Spring Data JPA repository for LocalProductView.",
    "contains": [
      "package com.test.orders.infrastructure.persistence.projections",
      "LocalProductViewJpaRepository",
      "JpaRepository<LocalProductViewJpa, UUID>"
    ]
  },

  "src/main/java/com/test/orders/infrastructure/projectionUpdaters/LocalProductViewProjectionUpdater.java": {
    "_comment": "Full-upsert RabbitMQ listener for primary source (ProductActivated). Creates row if absent.",
    "contains": [
      "package com.test.orders.infrastructure.projectionUpdaters",
      "class LocalProductViewProjectionUpdater",
      "@RabbitListener(queues = \"${queues.orders-projection-local-product-view-product-activated}\")",
      "orElseGet",
      "LocalProductViewJpa",
      "setProductName",
      "setPrice",
      "setLastUpdatedAt",
      "repository.save",
      "derived_from: bc.orders.projections[LocalProductView]"
    ],
    "notContains": [
      "ProductPriceChanged",
      "isEmpty()"
    ]
  },

  "src/main/java/com/test/orders/infrastructure/projectionUpdaters/LocalProductViewOnProductPriceChangedProjectionUpdater.java": {
    "_comment": "Partial updater: only updates price field; never inserts.",
    "contains": [
      "package com.test.orders.infrastructure.projectionUpdaters",
      "class LocalProductViewOnProductPriceChangedProjectionUpdater",
      "@RabbitListener(queues = \"${queues.orders-projection-local-product-view-product-price-changed}\")",
      "repository.findById(key)",
      "existing.isEmpty()",
      "setPrice",
      "setLastUpdatedAt",
      "repository.save",
      "derived_from: bc.orders.projections[LocalProductView].additionalSources[event=ProductPriceChanged]"
    ],
    "notContains": [
      "orElseGet",
      "setProductName"
    ]
  },

  "src/main/resources/db/migration/V2__projections.sql": {
    "_comment": "Single SQL migration for the one persistent projection in orders BC.",
    "contains": [
      "CREATE TABLE IF NOT EXISTS proj_local_product_view",
      "product_id",
      "product_name",
      "price",
      "last_updated_at"
    ]
  },

  "src/main/resources/parameters/local/rabbitmq.yaml": {
    "_comment": "RabbitMQ topology must include both queue keys: primary (ProductActivated) and partial (ProductPriceChanged).",
    "contains": [
      "orders-projection-local-product-view-product-activated",
      "orders-projection-local-product-view-product-price-changed",
      "catalog.events"
    ]
  }
}
